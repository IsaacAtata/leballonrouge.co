---
const { title = "Le Ballon Rouge" } = Astro.props;
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="fr" class="h-100">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="d-flex flex-column h-100">
    <header>
      <!-- Nav component will go here -->
      <nav class="navbar navbar-expand-lg lbr-nav py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3" href="/">
                <span class="lbr-brand-dot" aria-hidden="true"></span>
                <span class="d-flex flex-column lh-sm">
                    <span class="fw-bold">Le Ballon Rouge</span>
                    <span class="text-secondary small">Garderie francophone</span>
                </span>
            </a>

            <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav"
            aria-controls="navbarNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
            >
            <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/qui-sommes-nous/">Qui sommes-nous?</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/inscription/">Inscription</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/espace-parents/">Espace Parents</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/centres/">Centres</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/programmes/">Programmes</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/personnel/">Personnel</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" href="/gouvernance/">Gouvernance</a></li>

                    <li class="nav-item ms-lg-2">
                    <a class="btn btn-lbr" href="/inscription/">
                        Inscription <span aria-hidden="true">→</span>
                    </a>
                    </li>
                </ul>
            </div>
        </div>
      </nav>
    </header>

    <main class="flex-grow-1">
      <slot />
    </main>

    <footer class="lbr-footer py-5 mt-auto">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <p class="mb-2 small">
              © {new Date().getFullYear()} Garderie Le Ballon Rouge. Tous droits réservés.
            </p>
          </div>
          <div class="col-md-6 text-md-end">
            <p class="mb-0 small">
              <a href="/centres/hamilton/" class="text-white-50">Hamilton</a> |
              <a href="/centres/brantford/" class="text-white-50">Brantford</a>
            </p>
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap JS bundle (for navbar collapse, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>