---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import Toast from "../components/Toast.astro";
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const {
  title = "TODO: Page title",
  lang = "fr",
  description = "TODO: Page description",
} = Astro.props as { title?: string; lang?: Lang; description?: string };

const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title} | Le Ballon Rouge</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang} />
    <script src="https://code.iconify.design/3/3.1.1/iconify.min.js" defer></script>
  </head>

  <body class="min-h-screen text-slate-800 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only fixed left-4 top-4 z-50 rounded-xl bg-white px-3 py-2 shadow-lg focus:outline-none focus:ring-2 focus:ring-red-500"
    >
      {lang === "en" ? t.layout.skipLinkEn : t.layout.skipLinkFr}
    </a>

    <Nav lang={lang} />

    <main id="main">
      <slot />
    </main>

    <Footer lang={lang} />
    <BackToTop />

    <Toast /> 

    <!-- Smart sticky nav — hides on scroll down, reappears on scroll up -->
    <script is:inline>
      (function () {
        var header = document.querySelector('header');
        if (!header) return;

        /* ── Body padding ── */
        function setBodyPadding() {
          var h = header.offsetHeight;
          if (h > 0) document.body.style.paddingTop = h + 'px';
        }

        requestAnimationFrame(setBodyPadding);
        window.addEventListener('load',   setBodyPadding, { passive: true });
        window.addEventListener('resize', setBodyPadding, { passive: true });

        /* ── Scroll hide / show ── */
        var lastY     = window.scrollY;
        var ticking   = false;
        var THRESHOLD = 80;

        function update() {
          var currentY = window.scrollY;

          header.classList.toggle('is-scrolled', currentY > 10);

          if (currentY > THRESHOLD) {
            header.classList.toggle('nav-hidden', currentY > lastY);
          } else {
            header.classList.remove('nav-hidden');
          }

          lastY   = currentY;
          ticking = false;
        }

        window.addEventListener('scroll', function () {
          if (!ticking) { requestAnimationFrame(update); ticking = true; }
        }, { passive: true });

        /* ── Astro page transitions ── */
        document.addEventListener('astro:after-swap', function () {
          setBodyPadding();
          lastY = window.scrollY;
          header.classList.remove('nav-hidden', 'is-scrolled');
        });
      })();
    </script>

    <script src="/assets/scripts/legacy.js" is:inline></script>
  </body>
</html>