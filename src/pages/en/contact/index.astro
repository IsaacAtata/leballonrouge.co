---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const lang = "en";

const locations = [
  {
    id: "hamilton",
    city: "Hamilton",
    name: "Hamilton Centre",
    fullName: "Le Ballon Rouge Hamilton",
    address: "135 Bendamere Ave, Hamilton, ON L9C 1N4",
    phoneDisplay: "905-383-8371",
    phoneHref: "tel:19053838371",
    email: "leballonrouge@cscmonavenir.ca",
    hours: "Monday to Friday 7:00 AM — 5:30 PM",
    mapsQuery: encodeURIComponent("135 Bendamere Ave, Hamilton, ON L9C 1N4"),
    googlePlaceUrl:
      "https://www.google.com/maps/place/Le+Ballon+Rouge/@43.2340612,-79.8920059,17z/data=!4m15!1m8!3m7!1s0x882c9b19663e1913:0x3b7c4b5e166434dc!2s135+Bendamere+Ave,+Hamilton,+ON+L9C+1N4!3b1!8m2!3d43.2341417!4d-79.892331!16s%2Fg%2F11bw41tzwd!3m5!1s0x882c9b19663e1913:0x5fe06c0c04a1ded3!8m2!3d43.2340319!4d-79.8917385!16s%2Fg%2F1vrqb8ch?entry=ttu&g_ep=EgoyMDI2MDIxMS4wIKXMDSoASAFQAw%3D%3D",
  },
  {
    id: "brantford",
    city: "Brantford",
    name: "Brantford Centre",
    fullName: "Le Ballon Rouge Brantford",
    address: "60 Clench Ave, Brantford, ON N3T 1B8",
    phoneDisplay: "519-753-6541",
    phoneHref: "tel:15197536541",
    email: "leballonrougebrantford@cscmonavenir.ca",
    hours: "Monday to Friday 7:30 AM — 5:30 PM",
    mapsQuery: encodeURIComponent("60 Clench Ave, Brantford, ON N3T 1B8"),
    googlePlaceUrl:
      "https://www.google.com/maps/place/Ballon+Rouge+Brantford+Le/@43.1249678,-80.2692262,17z/data=!3m1!5s0x882c66224ef0d12b:0x7c74146ac0ce288b!4m15!1m8!3m7!1s0x882c662250f94ca7:0xa61c9f61580b00a2!2s60+Clench+Ave,+Brantford,+ON+N3T+1B9!3b1!8m2!3d43.1249678!4d-80.2692262!16s%2Fg%2F11c0vpmtmg!3m5!1s0x882c662248959271:0x878929e7f1c7180b!8m2!3d43.1249728!4d-80.2692683!16s%2Fg%2F1hc0sm54k?entry=ttu&g_ep=EgoyMDI2MDIxMS4wIKXMDSoASAFQAw%3D%3D",
  },
];

const generalEmail = "info@ballonrouge.ca";
---

<BaseLayout
  lang={lang}
  title="Contact — Le Ballon Rouge"
  description="Get in touch with Le Ballon Rouge in Hamilton or Brantford. Find phone numbers, email addresses, hours and maps for each centre."
>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <h1 class="text-3xl font-black tracking-tight md:text-5xl">Contact</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Contact us with any questions. To request a spot, please use the registration page.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/#comment-sinscrire"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Request a spot
      </a>
      <a
        href={`mailto:${generalEmail}`}
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Email {generalEmail}
      </a>
    </div>
  </section>

  <!-- Locations -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-6">
      {locations.map((loc) => (
        <article
          id={loc.id}
          class="scroll-mt-28 rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8"
        >
          <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
            <div class="max-w-2xl">
              <div class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white/70 px-4 py-2 text-xs font-extrabold uppercase tracking-wider text-slate-700">
                <span aria-hidden="true">📍</span>
                <span>{loc.city}</span>
              </div>

              <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-900 md:text-3xl">
                {loc.fullName}
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                <span class="font-extrabold">Address:</span> {loc.address}
              </p>
              <p class="mt-1 leading-7 text-slate-600">
                <span class="font-extrabold">Hours:</span> {loc.hours}
              </p>

              <div class="mt-6 flex flex-wrap gap-3">
                <a
                  href={loc.phoneHref}
                  class="inline-flex items-center justify-center rounded-full bg-red-700 px-5 py-2.5 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
                >
                  Call: {loc.phoneDisplay}
                </a>
                <a
                  href={`mailto:${loc.email}`}
                  class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
                >
                  Centre email
                </a>
                <a
                  href={loc.id === "hamilton" ? "/en/centres/hamilton/" : "/en/centres/brantford/"}
                  class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
                >
                  View centre page
                </a>
              </div>
            </div>

            <!-- Map -->
            <div class="w-full md:w-[420px]">
              <div class="rounded-[26px] border border-black/10 bg-white/70 p-3 shadow-lg shadow-black/5">
                <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-black/10 bg-white">
                  <iframe
                    title={`Map — ${loc.fullName}`}
                    class="h-full w-full"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    src={`https://www.google.com/maps?q=${loc.mapsQuery}&output=embed`}
                  />
                </div>

                <div class="mt-3 flex flex-wrap gap-2">
                  <a
                    href={loc.googlePlaceUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80"
                  >
                    Open in Google Maps
                  </a>
                  <a
                    href={loc.id === "hamilton" ? "/en/inscription/#hamilton" : "/en/inscription/#brantford"}
                    class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80"
                  >
                    Register — {loc.city}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Contact form -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <h2 class="text-xl font-black tracking-tight md:text-2xl">Send us a message</h2>
      <p class="mt-3 leading-7 text-slate-600">
        Have a question that isn't covered on this page? Fill out the form below and we'll get back to you.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/en/contact/merci/"
        class="mt-6 grid gap-4"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden"><label>Do not fill: <input name="bot-field" /></label></p>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">Full name *</label>
            <input required name="contact-nom" type="text" placeholder="Your name"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">Email *</label>
            <input required type="email" name="contact-email" placeholder="example@email.ca"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">Phone (optional)</label>
            <input name="contact-telephone" type="tel"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">Subject *</label>
            <select required name="contact-sujet"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500">
              <option value="" disabled selected>Select a subject</option>
              <option value="inscription">Registration / Waitlist</option>
              <option value="frais">Fees and subsidies</option>
              <option value="programmes">Programs</option>
              <option value="emploi">Job offer</option>
              <option value="gouvernance">Governance / Board</option>
              <option value="autre">Other</option>
            </select>
          </div>
        </div>

        <div>
          <label class="text-sm font-extrabold text-slate-700">Centre (optional)</label>
          <select name="contact-centre"
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500">
            <option value="">None / General</option>
            <option value="hamilton">Hamilton</option>
            <option value="brantford">Brantford</option>
          </select>
        </div>

        <div>
          <label class="text-sm font-extrabold text-slate-700">Message *</label>
          <textarea required name="contact-message"
            class="mt-2 min-h-[160px] w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            placeholder="Write your message here…"></textarea>
        </div>

        <p class="text-xs font-semibold text-slate-500">* Required fields</p>

        <button
          type="submit"
          class="mt-2 inline-flex justify-center rounded-2xl bg-red-700 px-5 py-3 text-sm font-extrabold text-white hover:bg-red-800"
        >
          Send message →
        </button>
      </form>
    </div>
  </section>

</BaseLayout>