---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SolidInfoCards from "../../components/SolidInfoCards.astro";
import StoryBlock from "../../components/StoryBlock.astro";
import CentresPreview from "../../components/CentresPreview.astro";
import PartnerTeaser from "../../components/PartnersTeaser.astro";
import TrueStats from "../../components/TrustStats.astro";
import TestimonialsPreview from "../../components/TestimonialsPreview.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import BottomCTA from "../../components/BottomCta.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="Home – Le Ballon Rouge"
  description="French-language daycare in Hamilton and Brantford. Learning through play, daily French immersion, and a safe and caring environment."
>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 pb-8 pt-8 md:pt-12">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div>
        <h1 class="text-3xl font-black tracking-tight md:text-5xl">
          A warm and safe French-language daycare
        </h1>

        <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
          Learning through play, exploration, nurturing routines and French every day.
        </p>

        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href="/en/inscription/"
            class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
          >
            Request a spot
          </a>

          <a
            href="/en/programmes/"
            class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
          >
            View our programs
          </a>
        </div>

        <div class="mt-6 flex flex-wrap gap-2 text-sm font-bold text-slate-600">
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-2">Qualified staff</span>
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-2">Safe environment</span>
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-2">French program</span>
        </div>
      </div>

      <div class="rounded-[28px] border border-black/10 bg-white/60 p-4 shadow-xl shadow-black/5">
        <div class="flex min-h-[260px] items-center justify-center rounded-2xl border border-dashed border-red-700/30 bg-gradient-to-br from-white to-[#fff3ea] text-slate-500">
          <span class="font-extrabold">Image / illustration</span>
        </div>
      </div>
    </div>
  </section>

  <SolidInfoCards lang={lang} />
  <StoryBlock lang={lang} />
  <CentresPreview lang={lang} />
  <PartnerTeaser lang={lang} />
  <TrueStats lang={lang} />
  <TestimonialsPreview lang={lang} />
  <FaqAccordion lang={lang} />
  <BottomCTA lang={lang} />

</BaseLayout>