---
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="Registration — Brantford"
  description="Request a spot at Le Ballon Rouge Brantford. Fill out the registration form to be placed on the waitlist for our French-language daycare centre."
>

  <!-- Page intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <h1 class="text-3xl font-black tracking-tight md:text-5xl">Registration — Brantford</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      To register at Le Ballon Rouge Brantford, please use the City of Brantford's centralized waitlist at
      <a href="https://brantford.onehsn.com" target="_blank" rel="noopener" class="font-extrabold text-red-700 hover:underline">brantford.onehsn.com</a>.
      Once on the list, our supervisor will confirm your request by phone or email.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/hamilton/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        See Hamilton
      </a>
      <a
        href="/en/contact/"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Contact us
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="grid gap-6 lg:grid-cols-5">

      <!-- Left: info -->
      <aside class="lg:col-span-2">
        <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
          <h2 class="text-xl font-black tracking-tight md:text-2xl">Brantford Centre</h2>
          <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-700">
            <li><span class="font-extrabold text-slate-900">Address:</span><br/>60 Clench Ave, Brantford, ON N3T 1B8</li>
            <li><span class="font-extrabold text-slate-900">Hours:</span><br/>Monday to Friday, 7:30 AM – 5:30 PM</li>
            <li><span class="font-extrabold text-slate-900">Phone:</span><br/><a href="tel:15197536541" class="text-red-700 hover:underline">519-753-6541</a></li>
            <li><span class="font-extrabold text-slate-900">Email:</span><br/><a href="mailto:leballonrougebrantford@cscmonavenir.ca" class="text-red-700 hover:underline">leballonrougebrantford@cscmonavenir.ca</a></li>
          </ul>

          <div class="mt-6 rounded-2xl border border-black/10 bg-slate-50 p-4">
            <p class="text-xs font-extrabold uppercase tracking-wide text-slate-500">How to register</p>
            <ol class="mt-2 space-y-2 text-xs font-semibold leading-5 text-slate-600 list-decimal list-inside">
              <li>Register on the centralized municipal waitlist at <a href="https://brantford.onehsn.com" class="text-red-700 hover:underline" target="_blank" rel="noopener">brantford.onehsn.com</a></li>
              <li>The list is in chronological order by registration date and time</li>
              <li>The supervisor will confirm your request by email or phone once received</li>
            </ol>
          </div>
        </article>
      </aside>

      <!-- Right: contact card (no online form — uses city system) -->
      <div class="lg:col-span-3">
        <article class="relative overflow-hidden rounded-[28px] border border-red-700/10 bg-white p-6 shadow-2xl shadow-red-700/10 ring-1 ring-black/5 md:p-10">
          <div class="pointer-events-none absolute -inset-24 bg-gradient-to-br from-red-50 via-white to-orange-50 opacity-70 blur-2xl"></div>

          <div class="relative space-y-6">
            <div>
              <h2 class="text-xl font-black tracking-tight md:text-2xl">Questions about registration?</h2>
              <p class="mt-2 leading-7 text-slate-600">
                If you have questions about the waitlist, available spots or admission conditions, contact our Brantford supervisor directly.
              </p>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              <a
                href="tel:15197536541"
                class="inline-flex items-center justify-center gap-2 rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
              >
                📞 Call 519-753-6541
              </a>
              <a
                href="mailto:leballonrougebrantford@cscmonavenir.ca"
                class="inline-flex items-center justify-center gap-2 rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
              >
                ✉️ Send an email
              </a>
            </div>

            <div class="rounded-2xl border border-amber-200 bg-amber-50 p-4">
              <p class="text-sm font-extrabold text-amber-800">⚠️ Important</p>
              <p class="mt-1 text-sm font-semibold leading-6 text-amber-700">
                Registration for Brantford is done exclusively through the City of Brantford's centralized waitlist system at
                <a href="https://brantford.onehsn.com" target="_blank" rel="noopener" class="underline">brantford.onehsn.com</a>.
                Once on the list, you have 48 hours to respond to an available spot offer.
              </p>
            </div>
          </div>
        </article>
      </div>

    </div>
  </section>

</BaseLayout>