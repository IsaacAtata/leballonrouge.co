---
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const lang = "en";
---

<BaseLayout
  lang={lang}
  title="Registration — Hamilton"
  description="Request a spot at Le Ballon Rouge Hamilton. Fill out the registration form to be placed on the waitlist for our French-language daycare centre."
>

  <!-- Page intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <h1 class="text-3xl font-black tracking-tight md:text-5xl">Registration — Hamilton</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Fill out the form below to be added to the waitlist for Le Ballon Rouge Hamilton. Our supervisor will
      confirm your request by phone or email within 48 hours.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/brantford/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        See Brantford
      </a>
      <a
        href="/en/contact/"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Contact us
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="grid gap-6 lg:grid-cols-5">

      <!-- Left: info -->
      <aside class="lg:col-span-2">
        <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
          <h2 class="text-xl font-black tracking-tight md:text-2xl">Hamilton Centre</h2>
          <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-700">
            <li><span class="font-extrabold text-slate-900">Address:</span><br/>135 Bendamere Ave, Hamilton, ON L9C 1N4</li>
            <li><span class="font-extrabold text-slate-900">Hours:</span><br/>Monday to Friday, 7:00 AM – 5:30 PM</li>
            <li><span class="font-extrabold text-slate-900">Phone:</span><br/><a href="tel:19053838371" class="text-red-700 hover:underline">905-383-8371</a></li>
            <li><span class="font-extrabold text-slate-900">Email:</span><br/><a href="mailto:leballonrouge@cscmonavenir.ca" class="text-red-700 hover:underline">leballonrouge@cscmonavenir.ca</a></li>
          </ul>

          <div class="mt-6 rounded-2xl border border-black/10 bg-white/60 p-4">
            <p class="text-xs font-extrabold uppercase tracking-wide text-slate-500">Admission priorities</p>
            <ol class="mt-2 space-y-1.5 text-xs font-semibold leading-5 text-slate-600 list-decimal list-inside">
              <li>Francophone families (at least one French-speaking parent)</li>
              <li>Children of Le Ballon Rouge staff</li>
              <li>Children transferring to an older age group</li>
              <li>Siblings of currently enrolled children</li>
              <li>Children of CSC Mon Avenir employees</li>
              <li>Siblings of students at partner schools</li>
            </ol>
          </div>
        </article>
      </aside>

      <!-- Right: form -->
      <div class="lg:col-span-3">
        <article class="relative overflow-hidden rounded-[28px] border border-red-700/10 bg-white p-6 shadow-2xl shadow-red-700/10 ring-1 ring-black/5 md:p-10">
          <div class="pointer-events-none absolute -inset-24 bg-gradient-to-br from-red-50 via-white to-orange-50 opacity-70 blur-2xl"></div>

          <div class="relative">
            <h2 class="text-xl font-black tracking-tight md:text-2xl">Registration form</h2>
            <p class="mt-2 max-w-prose leading-7 text-slate-600">
              All fields marked with * are required.
            </p>

            <form
              name="inscription-hamilton"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              action="/en/inscription/merci/"
              class="mt-6 space-y-10"
            >
              <!-- Netlify required hidden fields -->
              <input type="hidden" name="form-name" value="inscription-hamilton" />
              <p class="hidden"><label>Do not fill: <input name="bot-field" /></label></p>

              <!-- Child information -->
              <section class="space-y-5">
                <h3 class="text-lg font-black text-slate-900">Child information</h3>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Last name *</span>
                    <input required name="enfant-nom" type="text" placeholder="Last name"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">First name *</span>
                    <input required name="enfant-prenom" type="text" placeholder="First name"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Date of birth *</span>
                    <input required name="enfant-ddn" type="date"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Gender *</span>
                    <select required name="enfant-genre"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40">
                      <option value="" disabled selected>Select…</option>
                      <option value="fille">Female</option>
                      <option value="garcon">Male</option>
                      <option value="autre">Other / Prefer not to answer</option>
                    </select>
                  </label>
                </div>

                <label class="space-y-1 block">
                  <span class="text-sm font-extrabold text-slate-700">Language *</span>
                  <select required name="enfant-langue"
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40">
                    <option value="" disabled selected>Select…</option>
                    <option value="francais">French</option>
                    <option value="anglais">English</option>
                    <option value="les-deux">Both</option>
                  </select>
                </label>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Desired start date *</span>
                    <input required name="enfant-debut" type="date"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Group *</span>
                    <select required name="enfant-groupe"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40">
                      <option value="" disabled selected>Select…</option>
                      <option value="bambins">Toddlers (18–30 months)</option>
                      <option value="prescolaires">Preschool (2.5–4 years)</option>
                      <option value="parascolaires">Before & After School (4–12 years)</option>
                    </select>
                  </label>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Program *</span>
                    <select required name="enfant-programme"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40">
                      <option value="" disabled selected>Select…</option>
                      <option value="temps-plein">Full-time (5 days)</option>
                      <option value="temps-partiel">Part-time (min. 2 days)</option>
                    </select>
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Subsidy requested *</span>
                    <select required name="enfant-subvention"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40">
                      <option value="" disabled selected>Select…</option>
                      <option value="oui">Yes</option>
                      <option value="non">No</option>
                    </select>
                  </label>
                </div>

                <label class="space-y-1 block">
                  <span class="text-sm font-extrabold text-slate-700">Comments / Special needs</span>
                  <textarea name="commentaire" rows="4" placeholder="Allergies, special needs, additional info…"
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40"></textarea>
                </label>
              </section>

              <hr class="border-slate-200" />

              <!-- Parent information -->
              <section class="space-y-5">
                <h3 class="text-lg font-black text-slate-900">Parent / Guardian information</h3>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Last name *</span>
                    <input required name="parent-nom" type="text" placeholder="Last name"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">First name *</span>
                    <input required name="parent-prenom" type="text" placeholder="First name"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Phone *</span>
                    <input required name="parent-telephone" type="tel" placeholder="(514) 000-0000"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Email *</span>
                    <input required name="parent-email" type="email" placeholder="example@email.ca"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>
                </div>

                <h4 class="text-base font-black text-slate-900">Address</h4>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="space-y-1 sm:col-span-2">
                    <span class="text-sm font-extrabold text-slate-700">Street *</span>
                    <input required name="adresse-rue" type="text" placeholder="123 Main Street"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">City *</span>
                    <input required name="adresse-ville" type="text" placeholder="Hamilton"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Province *</span>
                    <input required name="adresse-province" type="text" placeholder="Ontario" value="Ontario"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>

                  <label class="space-y-1">
                    <span class="text-sm font-extrabold text-slate-700">Postal code *</span>
                    <input required name="adresse-postal" type="text" placeholder="L9C 1N4"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-semibold shadow-sm outline-none focus:ring-2 focus:ring-red-500/40" />
                  </label>
                </div>
              </section>

              <p class="text-xs font-semibold text-slate-500">* Required fields</p>

              <button
                type="submit"
                class="w-full rounded-2xl bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
              >
                Submit registration request →
              </button>
            </form>
          </div>
        </article>
      </div>

    </div>
  </section>

</BaseLayout>
