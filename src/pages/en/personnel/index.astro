---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const lang = "en";

const recognitions = [
  {
    title: "Continuous professional development",
    body: "Each staff member maintains a continuous professional learning plan grounded in self-reflection. The centre requires a minimum of four professional development events per year (January to December), and staff are familiarized with \"How Does Learning Happen? Ontario's Pedagogy for the Early Years.\"",
    icon: "📚",
  },
  {
    title: "A warm French-language environment",
    body: "Our team supports the overall development of children in a welcoming, safe and French-language environment, by valuing exploration and play.",
    icon: "🤝",
  },
  {
    title: "Partnerships and resources",
    body: "We collaborate with community resources to support children, families and staff whenever needed.",
    icon: "🧩",
  },
];
---

<BaseLayout
  lang={lang}
  title="Staff – Le Ballon Rouge"
  description="Meet the qualified and caring team at Le Ballon Rouge. Learn about our hiring approach, staff recognition, job openings and how to join our team."
>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <h1 class="text-3xl font-black tracking-tight md:text-5xl">Staff</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      A warm and qualified team, committed to the well-being, safety and learning of every child.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/personnel/#reconnaissances"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Employee recognition
      </a>
      <a
        href="#emplois"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Job openings
      </a>
      <a
        href="#rejoignez"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Join our team
      </a>
    </div>
  </section>

  <!-- Intro / who we hire -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <h2 class="text-xl font-black tracking-tight md:text-2xl">A qualified team</h2>
      <p class="mt-3 leading-7 text-slate-600">
        Le Ballon Rouge hires qualified early childhood educators as well as early childhood educator assistants, based on enrollment numbers
        and the Ministry's educator-to-child ratio requirements.
      </p>
      <p class="mt-3 leading-7 text-slate-600">
        From time to time, we welcome students from Early Childhood Education (college) programs to complete a placement at the daycare,
        enriching their professional experience. Before joining our programs, they review our internal policies and provide all required documentation.
      </p>

      <div class="mt-6 rounded-2xl border border-black/10 bg-white/70 p-5">
        <h3 class="text-lg font-black">Parents: you are always welcome</h3>
        <p class="mt-2 leading-7 text-slate-600">
          Parent participation is always welcome, and the invitation extends to other family members as well. Come play with us, attend activities,
          take part in a special celebration, share your feedback or sit on the board of directors.
        </p>
        <a
          href="/en/gouvernance/#joindre"
          class="mt-4 inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-6 py-3 text-sm font-extrabold shadow-sm hover:bg-white/80"
        >
          Join the board of directors
        </a>
      </div>
    </div>
  </section>

  <!-- Employee recognition -->
  <section id="reconnaissances" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-xl font-black tracking-tight md:text-2xl">Employee recognition</h2>
          <p class="mt-2 max-w-prose leading-7 text-slate-600">
            We value the dedication of our team and their continuous professional growth.
          </p>
        </div>
      </div>

      <div class="mt-6 grid gap-5 md:grid-cols-3">
        {recognitions.map((r) => (
          <article class="group rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-lg shadow-black/5 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-black/10">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-black/10 bg-white shadow-sm">
              <span aria-hidden="true" class="text-xl">{r.icon}</span>
            </div>
            <h3 class="mt-4 text-lg font-black text-slate-900">{r.title}</h3>
            <p class="mt-2 leading-7 text-slate-600">{r.body}</p>
          </article>
        ))}
      </div>

      <div class="mt-8 rounded-2xl border border-dashed border-black/15 bg-white/50 p-5">
        <p class="font-extrabold text-slate-900">To add (optional)</p>
        <p class="mt-2 leading-7 text-slate-600">
          You can display here: years of service, acknowledgements, completed training, and recognition messages (without sensitive personal data).
        </p>
      </div>
    </div>
  </section>

  <!-- Job openings -->
  <section id="emplois" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <h2 class="text-xl font-black tracking-tight md:text-2xl">Job openings</h2>
      <p class="mt-3 leading-7 text-slate-600">
        Posted positions vary based on centre needs and ratio requirements. To apply, please check the listings below or contact us directly.
      </p>

      <div class="mt-6 rounded-2xl border border-black/10 bg-white/70 p-5">
        <p class="font-extrabold text-slate-900">No openings posted at this time</p>
        <p class="mt-2 leading-7 text-slate-600">
          You are still welcome to send us an unsolicited application using the form below.
        </p>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="#rejoignez"
          class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
        >
          Send an unsolicited application
        </a>
        <a
          href="/en/contact/"
          class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>

  <!-- Join our team -->
  <section id="rejoignez" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <h2 class="text-xl font-black tracking-tight md:text-2xl">Join our team</h2>
      <p class="mt-3 leading-7 text-slate-600">
        Send us your application. We will reach out if a position matching your profile becomes available.
      </p>

      <form class="mt-6 grid gap-4" onsubmit="event.preventDefault(); alert('Thank you! (demo)');">
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">Full name</label>
            <input
              name="fullName"
              required
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">Email</label>
            <input
              type="email"
              name="email"
              required
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">Phone</label>
            <input
              name="phone"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">Preferred centre (optional)</label>
            <select
              name="preferredCentre"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            >
              <option value="">No preference</option>
              <option>Hamilton</option>
              <option>Brantford</option>
            </select>
          </div>
        </div>

        <div>
          <label class="text-sm font-extrabold text-slate-700">Message</label>
          <textarea
            name="message"
            class="mt-2 min-h-[140px] w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            placeholder="Introduce yourself and indicate the type of position you are looking for (educator, assistant, placement, etc.)."
          ></textarea>
        </div>

        <div>
          <label class="text-sm font-extrabold text-slate-700">Résumé (optional)</label>
          <input
            type="file"
            name="cv"
            accept=".pdf,.doc,.docx"
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm"
          />
          <p class="mt-2 text-xs font-semibold text-slate-500">
            (The file will only be submitted once the form is connected to a submission service.)
          </p>
        </div>

        <button
          class="mt-2 inline-flex justify-center rounded-2xl bg-red-700 px-5 py-3 text-sm font-extrabold text-white hover:bg-red-800"
        >
          Send my application
        </button>
      </form>
    </div>
  </section>

</BaseLayout>