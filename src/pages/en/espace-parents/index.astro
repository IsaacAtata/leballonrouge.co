---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const fraisDivers = [
  {
    icon: "⏰",
    title: "Late pickup fees",
    body: "A late pickup penalty applies for all departures after 5:30 PM. A fee of $10.00 per 15 minutes, per family, is paid directly to staff in cash. The daycare's clock will be used to determine the pickup time.",
    detail: [
      { range: "0 to 15 minutes",  amount: "$10.00 / family" },
      { range: "16 to 30 minutes", amount: "$20.00 / family" },
      { range: "31 to 45 minutes", amount: "$30.00 / family" },
      { range: "46 to 60 minutes", amount: "$40.00 / family" },
    ],
    note: "No tax receipt will be issued for late fees, as this is a penalty and not a regular childcare fee.",
  },
  {
    icon: "🏦",
    title: "Returned payment",
    body: "In the event of a returned or failed cheque, EFT or PAD payment, a $20.00 fee will be added to cover banking and administrative costs.",
    detail: null,
    note: null,
  },
];
---

<BaseLayout
  lang="en"
  title="Parent Space — Le Ballon Rouge"
  description="Guide, fees, subsidies, menu and useful resources for Le Ballon Rouge families in Hamilton and Brantford."
>

  <!-- Hero intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-1.5 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
      Families · Hamilton &amp; Brantford
    </div>
    <h1 class="mt-4 text-3xl font-black tracking-tight md:text-5xl">Parent Space</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Guide, fees, menu and useful resources to support your child at Le Ballon Rouge.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        How to register →
      </a>
      <a
        href="/en/contact/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Contact us
      </a>
    </div>

    <!-- Anchor nav -->
    <div class="mt-5 flex flex-wrap gap-2 text-sm font-bold text-slate-700">
      <a href="#guide"      class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Parent guide</a>
      <a href="#frais"      class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Fees &amp; subsidies</a>
      <a href="#divers"     class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Miscellaneous fees</a>
      <a href="#subvention" class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Subsidy</a>
      <a href="#menu"       class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Menu</a>
      <a href="#ressources" class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Resources</a>
    </div>
  </section>

  <!-- Parent guide -->
  <section id="guide" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Resource
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Parent guide</h2>
      <p class="mt-2 max-w-prose leading-7 text-slate-600">
        The daycare centre provides families with a guide containing useful information on registration and withdrawal, arrivals and departures, authorized persons, personal belongings, statutory holidays, vacations, illness, medication administration, supervision, and more.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="/public/assets/pdfs/2026-01 Guide des parents BRH.pdf"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
        >
          📄 Download the guide (PDF)
        </a>
        <a
          href="/en/contact/"
          class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
        >
          A question? Contact us
        </a>
      </div>
    </div>
  </section>

  <!-- Base fees -->
  <section id="frais" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        2025 Rates
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Fees and subsidies</h2>
      <p class="mt-2 max-w-prose leading-7 text-slate-600">
        Le Ballon Rouge is enrolled in the Canada-wide early learning and child care system. Please note that this does not apply to miscellaneous fees such as field trips, late pickup fees or non-sufficient funds fees.
      </p>

      <!-- Table -->
      <h3 class="mt-8 text-lg font-black text-slate-900">Base fees 2025</h3>
      <p class="mt-1 text-sm font-semibold text-slate-500">Full-time: 5 days · Part-time: minimum 2 days</p>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-black/10">
        <table class="w-full min-w-[640px] text-sm">
          <thead>
            <tr class="border-b border-black/10 bg-slate-50/80">
              <th class="px-4 py-3 text-left font-black text-slate-900">Centre</th>
              <th class="px-4 py-3 text-left font-black text-slate-900">
                Toddlers<br/>
                <span class="text-xs font-semibold text-slate-500">18 to 30 months</span>
              </th>
              <th class="px-4 py-3 text-left font-black text-slate-900">
                Preschool<br/>
                <span class="text-xs font-semibold text-slate-500">2.5 to 4 years</span>
              </th>
              <th class="px-4 py-3 text-left font-black text-slate-900">
                Before &amp; After School<br/>
                <span class="text-xs font-semibold text-slate-500">4 to 5 years</span>
              </th>
              <th class="px-4 py-3 text-left font-black text-slate-900">
                Before &amp; After School<br/>
                <span class="text-xs font-semibold text-slate-500">6 to 12 years</span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-black/5">
            <tr class="bg-white/60">
              <td class="px-4 py-4 font-black text-slate-900">Brantford</td>
              <td class="px-4 py-4">
                <span class="font-black text-red-700">$22.00</span><br/>
                <span class="text-xs text-slate-500">per day</span>
              </td>
              <td class="px-4 py-4">
                <span class="font-black text-red-700">$21.48</span><br/>
                <span class="text-xs text-slate-500">per day</span>
              </td>
              <td class="px-4 py-4 text-xs font-semibold leading-6 text-slate-700">
                AM: $11.36<br/>PM: $11.36<br/>AM &amp; PM: $12.00<br/>
                <span class="text-slate-500">PD/Holiday: $18.66</span>
              </td>
              <td class="px-4 py-4 text-xs font-semibold leading-6 text-slate-700">
                AM: $11.36<br/>PM: $11.36<br/>AM &amp; PM: $18.69<br/>
                <span class="text-slate-500">PD/Holiday: $39.50</span>
              </td>
            </tr>
            <tr class="bg-white/30">
              <td class="px-4 py-4 font-black text-slate-900">Hamilton</td>
              <td class="px-4 py-4">
                <span class="font-black text-red-700">$22.00</span><br/>
                <span class="text-xs text-slate-500">per day</span>
              </td>
              <td class="px-4 py-4">
                <span class="font-black text-red-700">$22.00</span><br/>
                <span class="text-xs text-slate-500">per day</span>
              </td>
              <td class="px-4 py-4 text-xs font-semibold leading-6 text-slate-700">
                AM: $11.36<br/>PM: $11.36<br/>AM &amp; PM: $12.00<br/>
                <span class="text-slate-500">PD/Holiday: $18.66</span>
              </td>
              <td class="px-4 py-4 text-xs font-semibold leading-6 text-slate-700">
                AM: $7.50<br/>PM: $7.50<br/>AM &amp; PM: $15.00<br/>
                <span class="text-slate-500">PD/Holiday: $39.50</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Fee notes -->
      <div class="mt-6 rounded-2xl border border-black/10 bg-white/60 p-5">
        <h3 class="font-black text-slate-900">Fee notes</h3>
        <ul class="mt-3 space-y-3">
          {[
            "Rates vary by program and attendance frequency. Fees are calculated based on the number of care days during opening hours and statutory holidays per month, excluding the Christmas closure and the summer closure week.",
            "No adjustment is made to fees for a child's absences, illness or vacation days. The daycare cannot guarantee your child's spot if you carry an outstanding balance.",
            "For part-time programs, days are fixed and non-exchangeable in order to comply with the ratios required by the Ministry of Education.",
          ].map((note) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-red-600"></span>
              <p class="text-sm font-semibold leading-6 text-slate-700">{note}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Miscellaneous fees -->
  <section id="divers" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="mb-6">
      <h2 class="text-2xl font-black tracking-tight md:text-3xl">Miscellaneous fees</h2>
      <p class="mt-2 max-w-2xl text-slate-600 md:text-lg">
        These fees are in addition to regular childcare fees and are not covered by the Canada-wide system.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {fraisDivers.map((f) => (
        <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-black/10 bg-white shadow-sm">
            <span aria-hidden="true" class="text-xl">{f.icon}</span>
          </div>
          <h3 class="mt-4 text-xl font-black tracking-tight">{f.title}</h3>
          <p class="mt-3 leading-7 text-slate-600">{f.body}</p>

          {f.detail && (
            <div class="mt-4 overflow-hidden rounded-2xl border border-black/10">
              {f.detail.map((row, i) => (
                <div class={`flex items-center justify-between px-4 py-3 ${i % 2 === 0 ? "bg-white/60" : "bg-slate-50/60"}`}>
                  <span class="text-sm font-semibold text-slate-700">{row.range}</span>
                  <span class="font-black text-red-700">{row.amount}</span>
                </div>
              ))}
            </div>
          )}

          {f.note && (
            <p class="mt-4 rounded-xl border border-amber-100 bg-amber-50/60 p-3 text-xs font-semibold leading-5 text-amber-800">
              ⚠️ {f.note}
            </p>
          )}
        </article>
      ))}
    </div>
  </section>

  <!-- Subsidy -->
  <section id="subvention" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Financial assistance
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Subsidy</h2>
      <p class="mt-2 max-w-prose leading-7 text-slate-600">
        Ontario residents may be eligible for a full or partial subsidy based on their financial situation. Eligibility criteria are managed by the city. Please contact your respective city to determine if you qualify. You must reach out to the <strong class="font-extrabold text-slate-800">Child Care Services</strong> division.
      </p>

      <div class="mt-6 grid gap-5 md:grid-cols-2">

        <!-- Brantford -->
        <article class="relative overflow-hidden rounded-[26px] border border-black/10 bg-gradient-to-br from-white/80 to-red-50/60 p-6 shadow-lg shadow-black/5">
          <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-red-700/10 blur-2xl"></div>
          <div class="flex items-start gap-3">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl border border-black/10 bg-white shadow-sm">
              <span aria-hidden="true" class="text-xl">🏫</span>
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-wider text-slate-500">Subsidy</p>
              <h3 class="text-xl font-black text-slate-900">Brantford</h3>
            </div>
          </div>
          <div class="mt-5 space-y-2 rounded-2xl border border-black/10 bg-white/70 p-4">
            <p class="text-sm font-semibold text-slate-700">
              📞 <a href="tel:5197597009" class="font-extrabold text-red-700 hover:text-red-900">(519) 759-7009</a>
            </p>
            <p class="text-sm font-semibold text-slate-700">
              🌐 <a href="https://brantford.ca/ChildrensServices" target="_blank" rel="noopener" class="font-extrabold text-red-700 underline underline-offset-4 hover:text-red-900">brantford.ca/ChildrensServices</a>
            </p>
            <p class="text-sm font-semibold text-slate-700">
              📍 220 Colborne Street, Brantford
            </p>
          </div>
        </article>

        <!-- Hamilton -->
        <article class="relative overflow-hidden rounded-[26px] border border-black/10 bg-gradient-to-br from-white/80 to-orange-50/60 p-6 shadow-lg shadow-black/5">
          <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-orange-500/10 blur-2xl"></div>
          <div class="flex items-start gap-3">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl border border-black/10 bg-white shadow-sm">
              <span aria-hidden="true" class="text-xl">📝</span>
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-wider text-slate-500">Subsidy</p>
              <h3 class="text-xl font-black text-slate-900">Hamilton</h3>
            </div>
          </div>
          <div class="mt-5 space-y-2 rounded-2xl border border-black/10 bg-white/70 p-4">
            <p class="text-sm font-semibold text-slate-700">
              📞 <a href="tel:9055464870" class="font-extrabold text-red-700 hover:text-red-900">(905) 546-4870</a>
            </p>
            <p class="text-sm font-semibold text-slate-700">
              🌐 <a href="https://www.hamilton.ca/social-services/early-years-and-child-care-services/financial-support-child-care" target="_blank" rel="noopener" class="font-extrabold text-red-700 underline underline-offset-4 hover:text-red-900">hamilton.ca · Child Care Financial Support</a>
            </p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Menu -->
  <section id="menu" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Nutrition
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Menu</h2>
      <p class="mt-2 leading-7 text-slate-600">
        View or download the monthly menu below. Our meals follow the recommendations of Canada's Food Guide.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="/docs/menu.pdf"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
        >
          📄 Download the menu (PDF)
        </a>
      </div>
    </div>
  </section>

  <!-- Resources -->
  <section id="ressources" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Family support
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Resources for parents</h2>
      <p class="mt-2 leading-7 text-slate-600">
        We collaborate with partners and community resources to support children, families and staff as needed.
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <article class="rounded-2xl border border-black/10 bg-white/60 p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white shadow-sm">
            <span aria-hidden="true" class="text-lg">🤝</span>
          </div>
          <h3 class="mt-3 font-black text-slate-900">Community resources</h3>
          <ul class="mt-3 space-y-2">
            {[
              "EarlyON Programs",
              "Public Health (Hamilton / Brantford)",
              "Lansdowne Children's Centre",
              "Community Living",
            ].map((r) => (
              <li class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-red-600"></span>
                {r}
              </li>
            ))}
          </ul>
        </article>

        <article class="rounded-2xl border border-black/10 bg-white/60 p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white shadow-sm">
            <span aria-hidden="true" class="text-lg">💬</span>
          </div>
          <h3 class="mt-3 font-black text-slate-900">Family communication</h3>
          <p class="mt-2 text-sm font-semibold leading-6 text-slate-600">
            Staff connect with families at drop-off and pick-up, and share information through communication tools and group postings for each age group.
          </p>
          <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">
            Parent involvement is always welcome, including during special activities or through the board of directors.
          </p>
        </article>

        <article class="rounded-2xl border border-black/10 bg-white/60 p-6 md:col-span-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white shadow-sm">
            <span aria-hidden="true" class="text-lg">♿</span>
          </div>
          <h3 class="mt-3 font-black text-slate-900">Accessibility &amp; inclusion</h3>
          <p class="mt-2 text-sm font-semibold leading-6 text-slate-600">
            Children with special needs can be integrated into the program with a positive approach. We encourage early screening, prevention and collaboration with available community resources.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-[28px] bg-gradient-to-br from-red-700 to-red-900 p-8 text-center shadow-2xl shadow-red-900/30 md:p-12">
      <p class="text-4xl font-black text-white">🎈</p>
      <h2 class="mt-3 text-2xl font-black text-white md:text-3xl">Any questions?</h2>
      <p class="mx-auto mt-3 max-w-prose text-base font-semibold leading-7 text-white/80">
        Our team is here to support you. Don't hesitate to contact the supervisor at your centre.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href="/en/contact/"
          class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-extrabold text-red-700 shadow-lg hover:bg-red-50"
        >
          Contact us →
        </a>
        <a
          href="/en/inscription/"
          class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3 text-sm font-extrabold text-white hover:bg-white/10"
        >
          Registration
        </a>
      </div>
    </div>
  </section>

</BaseLayout>