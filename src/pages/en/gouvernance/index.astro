---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const lang = "en";

const exec = [
  { role: "President",       name: "Mathieu Berlaud" },
  { role: "Vice-President",  name: "Cindy Fierbiger" },
  { role: "Treasurer",       name: "Chantal Giroux-Podstawka" },
  { role: "Secretary",       name: "Jose Guimond" },
  { role: "Administrator",   name: "Andrew Zadarnowski" },
  { role: "Administrator",   name: "Aurlélien Assonna" },
  { role: "Administrator",   name: "Dorothe Petit-Pas" },
  { role: "Administrator",   name: "Robert Brown" },
  { role: "Past President",  name: "Angela Wright" },
];

const sectors = [
  { value: "education",        label: "Education" },
  { value: "organisme-franco", label: "Francophone community organization" },
  { value: "ethnoculturel",    label: "Ethnocultural communities" },
  { value: "droit",            label: "Law" },
  { value: "finance",          label: "Finance and accounting" },
  { value: "communications",   label: "Communications" },
  { value: "ti",               label: "Information technology" },
  { value: "rh",               label: "Human resources" },
];
---

<BaseLayout
  lang={lang}
  title="Governance — Le Ballon Rouge"
  description="Learn about Le Ballon Rouge's board of directors, its mission and how to get involved in governing our French-language daycare centres."
>

  <!-- Page intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <h1 class="text-3xl font-black tracking-tight md:text-5xl">Governance</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      We place great importance on parent involvement in our programs, particularly through participation on the board of directors.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        How to register
      </a>
      <a
        href="#joindre"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Join the board
      </a>
    </div>
  </section>

  <!-- Why a board -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-5 md:grid-cols-2">
      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <h2 class="text-xl font-black tracking-tight md:text-2xl">Why a board of directors?</h2>
        <p class="mt-3 leading-7 text-slate-600">
          Volunteer involvement is essential to the smooth running of our organization. Being part of the board of directors means making a concrete commitment to the life of the centre your child attends.
        </p>
        <p class="mt-3 leading-7 text-slate-600">
          This commitment includes implementing the strategic plan, approving policies and procedures, reviewing the operating budget and evaluating the performance of the executive director.
        </p>
      </article>

      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <h2 class="text-xl font-black tracking-tight md:text-2xl">Mandate and operations</h2>
        <p class="mt-3 leading-7 text-slate-600">
          As the voice of the community, the board of directors plays an essential role in achieving Le Ballon Rouge's objectives. Its fiduciary mandate ensures rigorous governance and effective strategic direction.
        </p>
        <p class="mt-3 leading-7 text-slate-600">
          The board meets ten times per year, in person, alternating between the two centres.
        </p>
        <p class="mt-3 leading-7 text-slate-600">
          We sincerely thank our current and former members for their commitment and valuable contribution to our mission.
        </p>
      </article>
    </div>
  </section>

  <!-- Executive members -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <h2 class="text-xl font-black tracking-tight md:text-2xl">Executive members (2024–2025)</h2>
      <div class="mt-5 grid gap-3 md:grid-cols-2">
        {exec.map((m) => (
          <div class="rounded-2xl border border-black/10 bg-white/70 p-4">
            <p class="text-xs font-extrabold uppercase tracking-wide text-slate-500">{m.role}</p>
            <p class="mt-1 text-lg font-black text-slate-900">{m.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Join the board -->
  <section id="joindre" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <h2 class="text-xl font-black tracking-tight md:text-2xl">Join the board of directors</h2>
      <p class="mt-3 leading-7 text-slate-600">
        Fill out this form to submit your application. If your application is accepted, a criminal record check may be required.
      </p>

      <form
        name="candidature-ca"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/en/gouvernance/merci/"
        enctype="multipart/form-data"
        class="mt-6 grid gap-5"
      >
        <input type="hidden" name="form-name" value="candidature-ca" />
        <p class="hidden"><label>Do not fill: <input name="bot-field" /></label></p>

        <div>
          <label class="text-sm font-extrabold text-slate-700">Full name *</label>
          <input required name="ca-nom" type="text" placeholder="First and last name"
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">Email address *</label>
            <input required type="email" name="ca-email" placeholder="example@email.ca"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">Phone number *</label>
            <input required name="ca-telephone" type="tel" placeholder="(514) 000-0000"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
          </div>
        </div>

        <!-- Status -->
        <div>
          <p class="text-sm font-extrabold text-slate-700">Status *</p>
          <div class="mt-2 flex flex-wrap gap-4">
            <label class="flex items-center gap-2 font-semibold text-slate-800 cursor-pointer">
              <input type="radio" name="ca-statut" value="parent" required class="accent-red-700" /> Parent
            </label>
            <label class="flex items-center gap-2 font-semibold text-slate-800 cursor-pointer">
              <input type="radio" name="ca-statut" value="membre-communaute" class="accent-red-700" /> Community member
            </label>
          </div>
        </div>

        <!-- Sectors -->
        <div>
          <p class="text-sm font-extrabold text-slate-700">Area(s) of involvement *</p>
          <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-3">
            {sectors.map(({ value, label }) => (
              <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 cursor-pointer">
                <input type="checkbox" name="ca-secteur" value={value} class="accent-red-700" />
                {label}
              </label>
            ))}
          </div>
          <div class="mt-3">
            <label class="text-sm font-extrabold text-slate-700">Other (please specify)</label>
            <input name="ca-autre-secteur" type="text" placeholder="Specify…"
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
          </div>
        </div>

        <!-- Experience -->
        <div>
          <p class="text-sm font-extrabold text-slate-700">Experience / knowledge of childcare services in Ontario *</p>
          <div class="mt-2 flex flex-wrap gap-4">
            {["None", "Beginner", "Intermediate", "Advanced"].map((niveau) => (
              <label class="flex items-center gap-2 font-semibold text-slate-800 cursor-pointer">
                <input type="radio" name="ca-experience" value={niveau.toLowerCase()} required class="accent-red-700" />
                {niveau}
              </label>
            ))}
          </div>
        </div>

        <!-- CV + Motivation -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            Motivation & CV *
            <span class="font-semibold text-slate-400 normal-case"> — Describe your motivations below. You may also attach your CV (PDF, DOCX — 2MB max).</span>
          </label>
          <textarea required name="ca-motivation" rows="5"
            placeholder="Explain why you would like to join the board of directors…"
            class="mt-2 min-h-[140px] w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"></textarea>
          <input type="file" name="ca-cv" accept=".pdf,.docx,.xlsx"
            class="mt-2 text-sm font-semibold text-slate-600 file:mr-4 file:rounded-full file:border-0 file:bg-red-700 file:px-4 file:py-2 file:text-xs file:font-extrabold file:text-white hover:file:bg-red-800" />
        </div>

        <!-- Criminal record check -->
        <div>
          <p class="text-sm font-extrabold text-slate-700">
            Do you agree to a criminal record check if your application is accepted? *
          </p>
          <div class="mt-2 flex flex-wrap gap-4">
            <label class="flex items-center gap-2 font-semibold text-slate-800 cursor-pointer">
              <input type="radio" name="ca-verification" value="oui" required class="accent-red-700" /> Yes, I agree
            </label>
            <label class="flex items-center gap-2 font-semibold text-slate-800 cursor-pointer">
              <input type="radio" name="ca-verification" value="non" class="accent-red-700" /> No, I decline
            </label>
          </div>
        </div>

        <p class="text-xs font-semibold text-slate-500">* Required fields</p>

        <button
          type="submit"
          class="mt-2 inline-flex justify-center rounded-2xl bg-red-700 px-5 py-3 text-sm font-extrabold text-white hover:bg-red-800"
        >
          Submit my application →
        </button>
      </form>
    </div>
  </section>

</BaseLayout>