---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const exec = [
  { role: "President",        name: "Mathieu Berlaud" },
  { role: "Vice-President",   name: "Cindy Fierbiger" },
  { role: "Treasurer",        name: "Chantal Giroux-Podstawka" },
  { role: "Secretary",        name: "Josée Guimond" },
  { role: "Administrator",    name: "Andrew Zadarnowski" },
  { role: "Administrator",    name: "Aurélien Assonna" },
  { role: "Administrator",    name: "Dorothée Petit-Pas" },
  { role: "Administrator",    name: "Robert Brown" },
  { role: "Past President",   name: "Angela Wright" },
];

const sectors = [
  { value: "education",        label: "Education" },
  { value: "organisme-franco", label: "Francophone community organization" },
  { value: "ethnoculturel",    label: "Ethnocultural communities" },
  { value: "droit",            label: "Law" },
  { value: "finance",          label: "Finance and accounting" },
  { value: "communications",   label: "Communications" },
  { value: "ti",               label: "Information technology" },
  { value: "rh",               label: "Human resources" },
  { value: "autre",            label: "Other (please specify)" },
];

const responsabilites = [
  { icon: "📋", title: "Strategic plan",      body: "Implementation and monitoring of the organization's strategic plan." },
  { icon: "📜", title: "Policies",            body: "Approval of the daycare centre's policies and procedures." },
  { icon: "💰", title: "Budget",              body: "Review and approval of the annual operating budget." },
  { icon: "📊", title: "Evaluation",          body: "Performance evaluation of the executive director." },
  { icon: "🗣️", title: "Community voice",    body: "Representation of families and the Francophone community." },
  { icon: "🏛️", title: "Fiduciary mandate",  body: "Rigorous governance and effective strategic direction of the organization." },
];
---

<BaseLayout
  lang="en"
  title="Governance — Le Ballon Rouge"
  description="Learn about Le Ballon Rouge's board of directors, its mission and how to get involved in governing our French-language daycare centres."
>

  <!-- Hero intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-1.5 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
      Board of Directors
    </div>
    <h1 class="mt-4 text-3xl font-black tracking-tight md:text-5xl">Governance</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      We place great importance on parent involvement in our programs, particularly through voluntary participation on the board of directors.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="#ca"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Board members →
      </a>
      <a
        href="#rejoignez"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Join the board
      </a>
    </div>

    <!-- Anchor nav -->
    <div class="mt-5 flex flex-wrap gap-2 text-sm font-bold text-slate-700">
      <a href="#mandat"    class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Mandate</a>
      <a href="#ca"        class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Members 2024–2025</a>
      <a href="#rejoignez" class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Application form</a>
    </div>
  </section>

  <!-- Intro cards -->
  <section id="mandat" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-5 md:grid-cols-2">
      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          Commitment
        </div>
        <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Why a board of directors?</h2>
        <p class="mt-3 leading-7 text-slate-600">
          Volunteer involvement is essential to the smooth running of our organization. Being part of the board of directors means making a concrete commitment to the life of the centre your child attends.
        </p>
        <p class="mt-3 leading-7 text-slate-600">
          Members bring their expertise and support, and make informed decisions in the best interest of the organization.
        </p>
      </article>

      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          Operations
        </div>
        <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Mandate and meetings</h2>
        <p class="mt-3 leading-7 text-slate-600">
          As the voice of the community, the board of directors plays an essential role in achieving Le Ballon Rouge's objectives. Its fiduciary mandate ensures rigorous governance and effective strategic direction.
        </p>
        <div class="mt-4 flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3">
          <span class="text-2xl">📅</span>
          <p class="text-sm font-extrabold text-slate-700">
            10 meetings per year — in person, alternating between both centres.
          </p>
        </div>
      </article>
    </div>
  </section>

  <!-- Responsibilities -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Role
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Board responsibilities</h2>
      <p class="mt-2 leading-7 text-slate-600">
        This commitment includes, among others, the following responsibilities:
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {responsabilites.map((r) => (
          <article class="rounded-2xl border border-black/10 bg-white/60 p-5">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white shadow-sm">
              <span aria-hidden="true" class="text-lg">{r.icon}</span>
            </div>
            <h3 class="mt-3 font-black text-slate-900">{r.title}</h3>
            <p class="mt-2 text-sm font-semibold leading-6 text-slate-600">{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Board members -->
  <section id="ca" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        2024–2025
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Executive members</h2>
      <p class="mt-2 leading-7 text-slate-600">
        We sincerely thank our current and former members for their commitment and valuable contribution to our mission!
      </p>

      <div class="mt-6 grid gap-3 md:grid-cols-2">
        {exec.map((m) => (
          <div class="flex items-center gap-4 rounded-2xl border border-black/10 bg-white/60 p-4">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl border border-black/10 bg-white text-lg shadow-sm">
              👤
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-wide text-slate-500">{m.role}</p>
              <p class="mt-0.5 font-black text-slate-900">{m.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Join the board form -->
  <section id="rejoignez" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Apply
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Join the board of directors</h2>
      <p class="mt-2 leading-7 text-slate-600">
        Fill out this form to submit your application to the Le Ballon Rouge board of directors. If your application is accepted, a criminal record check will be required.
      </p>

      <form
        name="candidature-ca-en"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/en/gouvernance/merci/"
        enctype="multipart/form-data"
        class="mt-6 grid gap-5"
      >
        <input type="hidden" name="form-name" value="candidature-ca-en" />
        <p class="hidden"><label>Do not fill: <input name="bot-field" /></label></p>

        <!-- 1. Full name -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">1. Full name <span class="text-red-600">*</span></label>
          <input
            name="fullName"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>

        <!-- 2 & 3. Email + Phone -->
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">2. Email address <span class="text-red-600">*</span></label>
            <input
              type="email"
              name="email"
              required
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">3. Phone number <span class="text-red-600">*</span></label>
            <input
              name="phone"
              required
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
        </div>

        <!-- 4. Status -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">4. Status <span class="text-red-600">*</span></label>
          <select
            name="status"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Select your status</option>
            <option>Parent</option>
            <option>Community member</option>
          </select>
        </div>

        <!-- 5. Sectors -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            5. Do you work, have you worked, or are you involved in any of the following sectors? <span class="text-red-600">*</span>
          </label>
          <select
            name="sector"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Select a sector</option>
            {sectors.map(({ value, label }) => <option value={value}>{label}</option>)}
          </select>
        </div>

        <!-- 6. Childcare experience -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            6. Do you have experience or knowledge of how childcare services are organized and operated in Ontario? <span class="text-red-600">*</span>
          </label>
          <select
            name="childcareExperience"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Select a level</option>
            <option>None</option>
            <option>Beginner</option>
            <option>Intermediate</option>
            <option>Advanced</option>
          </select>
        </div>

        <!-- 7. CV + motivation -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            7. CV and motivation <span class="text-red-600">*</span>
          </label>
          <p class="mt-1 text-xs font-semibold text-slate-500">
            Please attach your CV and describe your motivation for joining our board of directors.
          </p>
          <input
            type="file"
            name="cv"
            accept=".pdf,.doc,.docx,.xls,.xlsx"
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm"
          />
          <p class="mt-1 text-xs font-semibold text-slate-400">PDF, DOCX, XLSX — 2MB max</p>
          <textarea
            name="motivation"
            required
            class="mt-3 min-h-[140px] w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            placeholder="Describe your motivation for joining the Le Ballon Rouge board of directors."
          ></textarea>
        </div>

        <!-- 8. Criminal record check -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            8. If your application is accepted, do you agree to undergo a criminal record check? <span class="text-red-600">*</span>
          </label>
          <select
            name="policeCheck"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Select an answer</option>
            <option value="oui">Yes, I agree</option>
            <option value="non">No, I decline</option>
          </select>
        </div>

        <button
          type="submit"
          class="mt-2 inline-flex justify-center rounded-2xl bg-red-700 px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
        >
          Submit my application
        </button>
      </form>
    </div>
  </section>


  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-[28px] bg-gradient-to-br from-red-700 to-red-900 p-8 text-center shadow-2xl shadow-red-900/30 md:p-12">
      <p class="text-4xl font-black text-white">🎈</p>
      <h2 class="mt-3 text-2xl font-black text-white md:text-3xl">Thank you to our volunteers!</h2>
      <p class="mx-auto mt-3 max-w-prose text-base font-semibold leading-7 text-white/80">
        We sincerely thank our current and former members for their commitment and valuable contribution to Le Ballon Rouge's mission.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href="#rejoignez"
          class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-extrabold text-red-700 shadow-lg hover:bg-red-50"
        >
          Join the board →
        </a>
        <a
          href="/en/contact/"
          class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3 text-sm font-extrabold text-white hover:bg-white/10"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>

</BaseLayout>