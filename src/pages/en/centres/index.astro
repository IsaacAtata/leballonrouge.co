---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const lang = "en";

const centres = [
  {
    slug: "hamilton",
    city: "Hamilton",
    name: "Le Ballon Rouge Hamilton",
    address: "135 Bendamere Ave, Hamilton, ON L9C 1N4",
    hours: "Monday to Friday 7:00 AM — 5:30 PM",
    supervisor: "Pierangela Lattuca",
    programs: ["Toddlers", "Preschool", "Before and After School"],
    pageHref: "/en/centres/hamilton/",
    inscriptionHref: "/en/inscription/#hamilton",
  },
  {
    slug: "brantford",
    city: "Brantford",
    name: "Le Ballon Rouge Brantford",
    address: "60 Clench Ave, Brantford, ON N3T 1B8",
    hours: "Monday to Friday 7:30 AM — 5:30 PM",
    supervisor: "Awatef Belghiti",
    programs: ["Toddlers", "Preschool", "Before and After School"],
    pageHref: "/en/centres/brantford/",
    inscriptionHref: "/en/inscription/#brantford",
  },
];
---

<BaseLayout
  lang={lang}
  title="Centres — Le Ballon Rouge"
  description="Discover our two French-language daycare centres in Ontario: Hamilton and Brantford."
>

  <!-- Page intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <h1 class="text-3xl font-black tracking-tight md:text-5xl">Our centres</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Two French-language centres in Ontario: Hamilton and Brantford.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/#comment-sinscrire"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        How to register
      </a>
      <a
        href="/en/centres/hamilton/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Hamilton centre
      </a>
      <a
        href="/en/centres/brantford/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Brantford centre
      </a>
    </div>
  </section>

  <!-- Centre cards -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-5 md:grid-cols-2">
      {centres.map((c) => (
        <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
          <div class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white/70 px-4 py-2 text-xs font-extrabold uppercase tracking-wider text-slate-700">
            <span aria-hidden="true">📍</span>
            <span>{c.city}</span>
          </div>

          <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-900">{c.name}</h2>

          <p class="mt-3 leading-7 text-slate-600">
            <span class="font-extrabold">Address:</span> {c.address}
          </p>
          <p class="mt-1 leading-7 text-slate-600">
            <span class="font-extrabold">Hours:</span> {c.hours}
          </p>
          <p class="mt-1 leading-7 text-slate-600">
            <span class="font-extrabold">Supervisor:</span> {c.supervisor}
          </p>

          <div class="mt-5 flex flex-wrap gap-2 text-sm font-bold text-slate-700">
            {c.programs.map((p) => (
              <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2">{p}</span>
            ))}
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={c.pageHref}
              class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
            >
              View centre
            </a>
            <a
              href={c.inscriptionHref}
              class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
            >
              Register — {c.city}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>