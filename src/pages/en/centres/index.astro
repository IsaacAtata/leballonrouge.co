---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const centres = [
  {
    slug: "hamilton",
    city: "Hamilton",
    name: "Le Ballon Rouge Hamilton",
    address: "135 Bendamere Ave, Hamilton, ON L9C 1N4",
    hours: "Monday to Friday 7:00 AM — 5:30 PM",
    phone: "905-383-8371",
    phoneTel: "19053838371",
    email: "leballonrouge@cscmonavenir.ca",
    supervisor: "Pierangela Lattuca",
    school: "École élémentaire Mon Seigneur de Laval",
    programs: ["Toddlers", "Preschool", "Before and After School"],
    inscriptionHref: "/en/inscription/hamilton/",
    mapsQuery: encodeURIComponent("135 Bendamere Ave, Hamilton, ON L9C 1N4"),
    googlePlaceUrl:
      "https://www.google.com/maps/place/Le+Ballon+Rouge/@43.2340612,-79.8920059,17z/data=!4m15!1m8!3m7!1s0x882c9b19663e1913:0x3b7c4b5e166434dc!2s135+Bendamere+Ave,+Hamilton,+ON+L9C+1N4!3b1!8m2!3d43.2341417!4d-79.892331!16s%2Fg%2F11bw41tzwd!3m5!1s0x882c9b19663e1913:0x5fe06c0c04a1ded3!8m2!3d43.2340319!4d-79.8917385!16s%2Fg%2F1vrqb8ch?entry=ttu",
  },
  {
    slug: "brantford",
    city: "Brantford",
    name: "Le Ballon Rouge Brantford",
    address: "60 Clench Ave, Brantford, ON N3T 1B8",
    hours: "Monday to Friday 7:30 AM — 5:30 PM",
    phone: "519-753-6541",
    phoneTel: "15197536541",
    email: "leballonrougebrantford@cscmonavenir.ca",
    supervisor: "Awatef Belghiti",
    school: "École élémentaire Sainte Marguerite Bourgeoys",
    programs: ["Toddlers", "Preschool", "Before and After School"],
    inscriptionHref: "/en/inscription/brantford/",
    mapsQuery: encodeURIComponent("60 Clench Ave, Brantford, ON N3T 1B8"),
    googlePlaceUrl:
      "https://www.google.com/maps/place/Ballon+Rouge+Brantford+Le/@43.1249678,-80.2692262,17z/data=!3m1!5s0x882c66224ef0d12b:0x7c74146ac0ce288b!4m15!1m8!3m7!1s0x882c662250f94ca7:0xa61c9f61580b00a2!2s60+Clench+Ave,+Brantford,+ON+N3T+1B9!3b1!8m2!3d43.1249678!4d-80.2692262!16s%2Fg%2F11c0vpmtmg!3m5!1s0x882c662248959271:0x878929e7f1c7180b!8m2!3d43.1249728!4d-80.2692683!16s%2Fg%2F1hc0sm54k?entry=ttu",
  },
];
---

<BaseLayout
  lang="en"
  title="Centres — Le Ballon Rouge"
  description="Discover our two French-language daycare centres in Ontario: Hamilton and Brantford."
>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-1.5 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
      Ontario · 2 centres
    </div>
    <h1 class="mt-4 text-3xl font-black tracking-tight md:text-5xl">Our centres</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Two French-language centres in Ontario — Hamilton and Brantford — offering licensed programs for toddlers, preschoolers, and before and after school care.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        How to register →
      </a>
      <a
        href="#hamilton"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        📍 Hamilton
      </a>
      <a
        href="#brantford"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        📍 Brantford
      </a>
    </div>
  </section>

  <!-- One section per centre -->
  {centres.map((c) => (
    <section id={c.slug} class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-16">

      <!-- Section header -->
      <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
            📍 {c.city}
          </div>
          <h2 class="mt-2 text-2xl font-black tracking-tight md:text-3xl">{c.name}</h2>
          <p class="mt-1 text-sm font-semibold text-slate-500">{c.address} · {c.hours}</p>
        </div>
        <a
          href={c.inscriptionHref}
          class="inline-flex flex-shrink-0 items-center justify-center rounded-full bg-red-700 px-5 py-2.5 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
        >
          Register — {c.city} →
        </a>
      </div>

      <!-- Info + Map grid -->
      <div class="grid gap-5 md:grid-cols-2">

        <!-- Info card -->
        <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
          <h3 class="text-lg font-black tracking-tight">Contact information</h3>

          <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-700">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-base">📍</span>
              <span>{c.address}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-base">🕐</span>
              <span>{c.hours}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-base">👩‍🏫</span>
              <span><span class="font-extrabold text-slate-900">Supervisor:</span> {c.supervisor}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-base">🏫</span>
              <span><span class="font-extrabold text-slate-900">School:</span> {c.school}</span>
            </li>
          </ul>

          <div class="mt-5 space-y-2">
            <a
              href={`tel:${c.phoneTel}`}
              class="flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3 text-sm font-extrabold text-slate-800 hover:bg-white"
            >
              📞 {c.phone}
            </a>
            <a
              href={`mailto:${c.email}`}
              class="flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3 text-sm font-extrabold text-red-700 hover:bg-white"
            >
              ✉️ {c.email}
            </a>
          </div>

          <div class="mt-5">
            <p class="text-sm font-extrabold text-slate-900">Programs offered</p>
            <div class="mt-2 flex flex-wrap gap-2">
              {c.programs.map((p) => (
                <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1.5 text-xs font-extrabold text-slate-700">
                  {p}
                </span>
              ))}
            </div>
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={c.inscriptionHref}
              class="inline-flex items-center justify-center rounded-full bg-red-700 px-5 py-2.5 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
            >
              Register →
            </a>
            <a
              href="/en/programmes/"
              class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
            >
              Our programs
            </a>
            <a
              href="/en/contact/"
              class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
            >
              Contact us
            </a>
          </div>
        </article>

        <!-- Map card -->
        <div class="rounded-[28px] border border-black/10 bg-white/70 p-3 shadow-xl shadow-black/5">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-black/10 bg-white">
            <iframe
              title={`Map — ${c.city} Centre`}
              class="h-full w-full"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src={`https://www.google.com/maps?q=${c.mapsQuery}&output=embed`}
            />
          </div>
          <div class="mt-3 flex flex-wrap gap-2 px-2 pb-2">
            <a
              href={c.googlePlaceUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80"
            >
              🗺️ Open in Google Maps
            </a>
            <a
              href={`https://www.google.com/maps/dir/?api=1&destination=${c.mapsQuery}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80"
            >
              🧭 Get directions
            </a>
          </div>
        </div>

      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-[28px] bg-gradient-to-br from-red-700 to-red-900 p-8 text-center shadow-2xl shadow-red-900/30 md:p-12">
      <p class="text-4xl font-black text-white">🎈</p>
      <h2 class="mt-3 text-2xl font-black text-white md:text-3xl">Ready to join Le Ballon Rouge?</h2>
      <p class="mx-auto mt-3 max-w-prose text-base font-semibold leading-7 text-white/80">
        Register your child today and give them a warm, stimulating French-language learning environment.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href="/en/inscription/hamilton/"
          class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-extrabold text-red-700 shadow-lg hover:bg-red-50"
        >
          Register — Hamilton →
        </a>
        <a
          href="/en/inscription/brantford/"
          class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3 text-sm font-extrabold text-white hover:bg-white/10"
        >
          Register — Brantford →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>