---
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const c = {
  city: "Hamilton",
  name: "Le Ballon Rouge Hamilton",
  address: "135 Bendamere Ave, Hamilton, ON L9C 1N4",
  hours: "Monday to Friday 7:00 AM — 5:30 PM",
  phone: "905-383-8371",
  phoneTel: "19053838371",
  email: "leballonrouge@cscmonavenir.ca",
  supervisor: "Pierangela Lattuca",
  school: "Mon Seigneur de Laval Elementary School",
  programs: ["Toddlers", "Preschool", "Before & After School"],
  inscriptionHref: "/en/inscription/hamilton/",
  mapsQuery: encodeURIComponent("135 Bendamere Ave, Hamilton, ON L9C 1N4"),
  googlePlaceUrl: "https://www.google.com/maps/place/Le+Ballon+Rouge/@43.2340612,-79.8920059,17z/data=!4m15!1m8!3m7!1s0x882c9b19663e1913:0x3b7c4b5e166434dc!2s135+Bendamere+Ave,+Hamilton,+ON+L9C+1N4!3b1!8m2!3d43.2341417!4d-79.892331!16s%2Fg%2F11bw41tzwd!3m5!1s0x882c9b19663e1913:0x5fe06c0c04a1ded3!8m2!3d43.2340319!4d-79.8917385!16s%2Fg%2F1vrqb8ch?entry=ttu",
  gallery: [
    { src: "", alt: "Play room — toddlers in activity" },
    { src: "", alt: "Our educator team" },
    { src: "", alt: "Outdoor play area" },
    { src: "", alt: "Preschool activities" },
    { src: "", alt: "Reading corner" },
    { src: "", alt: "After-school program" },
  ],
};
---

<BaseLayout lang="en" title={`${c.name} — Le Ballon Rouge`} description={`Discover the ${c.name} centre in ${c.city}, Ontario.`}>

  <section class="mx-auto max-w-6xl px-4 pb-6 pt-8 md:pt-12">
    <a href="/en/centres/" class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-black uppercase tracking-widest text-slate-700 shadow-sm hover:bg-slate-50">
      ← Back to centres
    </a>

    <div class="mt-6 flex flex-wrap items-start justify-between gap-4">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          📍 {c.city}
        </div>
        <h1 class="mt-3 text-3xl font-black tracking-tight md:text-5xl">{c.name}</h1>
        <p class="mt-2 text-sm font-semibold text-slate-500">{c.address} · {c.hours}</p>
      </div>
      <a href={c.inscriptionHref} class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800">
        Register — {c.city} →
      </a>
    </div>
  </section>

  <!-- Info + Map -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="grid gap-5 md:grid-cols-2">

      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <h3 class="text-lg font-black tracking-tight">Contact Details</h3>
        <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-700">
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">📍</span><span>{c.address}</span></li>
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">🕐</span><span>{c.hours}</span></li>
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">👩‍🏫</span><span><span class="font-extrabold text-slate-900">Supervisor:</span> {c.supervisor}</span></li>
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">🏫</span><span><span class="font-extrabold text-slate-900">School:</span> {c.school}</span></li>
        </ul>

        <div class="mt-5 space-y-2">
          <a href={`tel:${c.phoneTel}`} class="flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3 text-sm font-extrabold text-slate-800 hover:bg-white">📞 {c.phone}</a>
          <a href={`mailto:${c.email}`} class="flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3 text-sm font-extrabold text-red-700 hover:bg-white">✉️ {c.email}</a>
        </div>

        <div class="mt-5">
          <p class="text-sm font-extrabold text-slate-900">Programs Offered</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {c.programs.map((p) => (
              <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1.5 text-xs font-extrabold text-slate-700">{p}</span>
            ))}
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href={c.inscriptionHref} class="inline-flex items-center justify-center rounded-full bg-red-700 px-5 py-2.5 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800">Register →</a>
          <a href="/en/programmes/" class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white">Our Programs</a>
          <a href="/en/contact/" class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white">Contact Us</a>
        </div>
      </article>

      <div class="rounded-[28px] border border-black/10 bg-white/70 p-3 shadow-xl shadow-black/5">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-black/10 bg-white">
          <iframe title={`Map — ${c.city} Centre`} class="h-full w-full" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src={`https://www.google.com/maps?q=${c.mapsQuery}&output=embed`} />
        </div>
        <div class="mt-3 flex flex-wrap gap-2 px-2 pb-2">
          <a href={c.googlePlaceUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80">🗺️ Open in Google Maps</a>
          <a href={`https://www.google.com/maps/dir/?api=1&destination=${c.mapsQuery}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80">🧭 Get Directions</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Gallery -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <h2 class="mb-4 text-lg font-black tracking-tight">Our Centre in Photos</h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      {c.gallery.map((img) => (
        <div class="hero-img-skeleton aspect-square">
          <div class="hero-img-skeleton-content">
            <span class="hero-img-balloon">🎈</span>
            <p class="hero-img-label px-3 text-center">{img.alt}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-3 text-xs font-semibold text-slate-400">Photos coming soon — staff and children from the {c.city} centre.</p>
  </section>

</BaseLayout>