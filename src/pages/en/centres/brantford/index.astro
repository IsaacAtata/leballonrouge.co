---
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const lang = "en";

const address = "60 Clench Ave, Brantford, ON N3T 1B8";
const mapsQuery = encodeURIComponent(address);

const googlePlaceUrl =
  "https://www.google.com/maps/place/Ballon+Rouge+Brantford+Le/@43.1249678,-80.2692262,17z/data=!3m1!5s0x882c66224ef0d12b:0x7c74146ac0ce288b!4m15!1m8!3m7!1s0x882c662250f94ca7:0xa61c9f61580b00a2!2s60+Clench+Ave,+Brantford,+ON+N3T+1B9!3b1!8m2!3d43.1249678!4d-80.2692262!16s%2Fg%2F11c0vpmtmg!3m5!1s0x882c662248959271:0x878929e7f1c7180b!8m2!3d43.1249728!4d-80.2692683!16s%2Fg%2F1hc0sm54k?entry=ttu&g_ep=EgoyMDI2MDIxMS4wIKXMDSoASAFQAw%3D%3D";
---

<BaseLayout
  lang={lang}
  title="Brantford Centre — Le Ballon Rouge"
  description="Le Ballon Rouge Brantford — French-language daycare at 60 Clench Ave. Hours, programs, contact information and map."
>

  <!-- Page intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <div class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white/70 px-4 py-2 text-xs font-extrabold uppercase tracking-wider text-slate-700">
      <span aria-hidden="true">📍</span>
      <span>Brantford</span>
    </div>

    <h1 class="mt-3 text-3xl font-black tracking-tight md:text-5xl">Le Ballon Rouge Brantford</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      {address} • Monday to Friday 7:30 AM — 5:30 PM
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/en/inscription/#brantford"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Register — Brantford
      </a>
      <a
        href="/en/centres/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Back to centres
      </a>
      <a
        href="/en/centres/hamilton/"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        See Hamilton
      </a>
    </div>
  </section>

  <!-- Details + map -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-6 md:grid-cols-2">

      <!-- Contact info -->
      <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <h2 class="text-xl font-black tracking-tight md:text-2xl">Contact information</h2>

        <p class="mt-3 leading-7 text-slate-600">
          <span class="font-extrabold">Address:</span> {address}
        </p>
        <p class="mt-1 leading-7 text-slate-600">
          <span class="font-extrabold">Phone:</span>{" "}
          <a class="text-red-700 underline underline-offset-4 hover:text-red-900" href="tel:15197536541">
            519-753-6541
          </a>
        </p>
        <p class="mt-1 leading-7 text-slate-600">
          <span class="font-extrabold">Email:</span>{" "}
          <a class="text-red-700 underline underline-offset-4 hover:text-red-900" href="mailto:leballonrougebrantford@cscmonavenir.ca">
            leballonrougebrantford@cscmonavenir.ca
          </a>
        </p>
        <p class="mt-1 leading-7 text-slate-600">
          <span class="font-extrabold">Supervisor:</span> Awatef Belghiti
        </p>
        <p class="mt-1 leading-7 text-slate-600">
          <span class="font-extrabold">School:</span> École élémentaire Sainte Marguerite Bourgeoys
        </p>
        <p class="mt-1 leading-7 text-slate-600">
          <span class="font-extrabold">Hours:</span> Monday to Friday 7:30 AM — 5:30 PM
        </p>

        <h3 class="mt-6 text-lg font-black">Programs offered</h3>
        <div class="mt-3 flex flex-wrap gap-2 text-sm font-bold text-slate-700">
          <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2">Toddlers</span>
          <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2">Preschool</span>
          <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2">Before and After School</span>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/en/programmes/"
            class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
          >
            Explore programs
          </a>
          <a
            href="/en/contact/"
            class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
          >
            Contact us
          </a>
        </div>
      </div>

      <!-- Map -->
      <div class="rounded-[28px] border border-black/10 bg-white/70 p-3 shadow-xl shadow-black/5">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-black/10 bg-white">
          <iframe
            title="Map — Brantford Centre"
            class="h-full w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src={`https://www.google.com/maps?q=${mapsQuery}&output=embed`}
          />
        </div>

        <div class="mt-3 flex flex-wrap gap-2 px-3 pb-3">
          <a
            href={googlePlaceUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80"
          >
            Open in Google Maps
          </a>
          <a
            href="/en/inscription/#comment-sinscrire"
            class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80"
          >
            How to register
          </a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>