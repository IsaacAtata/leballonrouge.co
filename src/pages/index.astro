---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SolidInfoCards from "../components/SolidInfoCards.astro";
import StoryBlock from "../components/StoryBlock.astro";
import CentresPreview from "../components/CentresPreview.astro";
import PartnersTeaser from "../components/PartnersTeaser.astro";
import TrustStats from "../components/TrustStats.astro";
import TestimonialsPreview from "../components/TestimonialsPreview.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import BottomCta from "../components/BottomCta.astro";
import BackToTop from "../components/BackToTop.astro"; 
---

<BaseLayout
  lang="fr"
  title="Accueil – Le Ballon Rouge"
  description="Service de garde francophone chaleureux et sécuritaire à Hamilton et Brantford."
>
  <Hero />
  <SolidInfoCards lang="fr" />
  <StoryBlock lang="fr" />
  <CentresPreview lang="fr" />
  <PartnersTeaser lang="fr" />
  <TrustStats lang="fr" />
  <TestimonialsPreview lang="fr" />
  <FaqAccordion lang="fr" />
  <BottomCta lang="fr" />

  <BackToTop />
  <script src="/assets/scripts/legacy.js" is:inline></script>
</BaseLayout>