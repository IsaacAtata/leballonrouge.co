---
import BaseLayout from "../../layouts/BaseLayout.astro";

const exec = [
  { role: "Président",           name: "Mathieu Berlaud" },
  { role: "Vice-présidente",     name: "Cindy Fierbiger" },
  { role: "Trésorière",          name: "Chantal Giroux-Podstawka" },
  { role: "Secrétaire",          name: "Josée Guimond" },
  { role: "Administrateur",      name: "Andrew Zadarnowski" },
  { role: "Administrateur",      name: "Aurélien Assonna" },
  { role: "Administratrice",     name: "Dorothée Petit-Pas" },
  { role: "Administrateur",      name: "Robert Brown" },
  { role: "Présidente sortante", name: "Angela Wright" },
];

const sectors = [
  "Éducation",
  "Organisme communautaire francophone",
  "Communautés ethnoculturelles",
  "Droit",
  "Secteur financier et comptable",
  "Communications",
  "Technologies de l'information",
  "Ressources humaines",
  "Autre (préciser)",
];

const responsabilites = [
  { icon: "📋", title: "Plan stratégique",   body: "Mise en œuvre et suivi du plan stratégique de l'organisme." },
  { icon: "📜", title: "Politiques",         body: "Approbation des politiques et procédures du centre de garde." },
  { icon: "💰", title: "Budget",             body: "Analyse et approbation du budget de fonctionnement annuel." },
  { icon: "📊", title: "Évaluation",         body: "Évaluation du rendement de la direction générale." },
  { icon: "🗣️", title: "Voix communautaire", body: "Représentation des familles et de la communauté francophone." },
  { icon: "🏛️", title: "Mandat fiduciaire",  body: "Gouvernance rigoureuse et orientation stratégique efficace de l'organisme." },
];
---

<BaseLayout
  lang="fr"
  title="Gouvernance — Le Ballon Rouge"
  description="Découvrez le conseil d'administration du Ballon Rouge et comment vous joindre à notre équipe de gouvernance."
>

  <!-- Hero intro -->
  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-1.5 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
      Conseil d'administration
    </div>
    <h1 class="mt-4 text-3xl font-black tracking-tight md:text-5xl">Gouvernance</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Nous accordons une grande importance à l'engagement des parents dans nos programmes, notamment par leur participation bénévole au sein du conseil d'administration.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="#ca"
        class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800"
      >
        Membres du CA →
      </a>
      <a
        href="#rejoignez"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-6 py-3 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white"
      >
        Se joindre au CA
      </a>
    </div>

    <!-- Anchor nav -->
    <div class="mt-5 flex flex-wrap gap-2 text-sm font-bold text-slate-700">
      <a href="#mandat"    class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Mandat</a>
      <a href="#ca"        class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Membres 2024–2025</a>
      <a href="#rejoignez" class="rounded-full border border-black/10 bg-white/60 px-3 py-2 hover:bg-white">Formulaire de candidature</a>
    </div>
  </section>


  <!-- Intro cards -->
  <section id="mandat" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-5 md:grid-cols-2">
      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          Engagement
        </div>
        <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Pourquoi un conseil d'administration?</h2>
        <p class="mt-3 leading-7 text-slate-600">
          Leur implication bénévole est essentielle au bon fonctionnement de notre organisme. Faire partie du conseil d'administration, c'est s'engager concrètement dans la vie du centre que fréquente son enfant.
        </p>
        <p class="mt-3 leading-7 text-slate-600">
          Les membres apportent leur expertise et leur soutien, et prennent des décisions éclairées dans le meilleur intérêt de l'organisme.
        </p>
      </article>

      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          Fonctionnement
        </div>
        <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Mandat et réunions</h2>
        <p class="mt-3 leading-7 text-slate-600">
          En tant que voix de la communauté, le conseil d'administration joue un rôle essentiel dans l'atteinte des objectifs du Ballon Rouge. Son mandat fiduciaire, à la fois unique et crucial, assure une gouvernance rigoureuse et une orientation stratégique efficace.
        </p>
        <div class="mt-4 flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3">
          <span class="text-2xl">📅</span>
          <p class="text-sm font-extrabold text-slate-700">
            10 réunions par année — en présentiel, en alternant dans les deux centres.
          </p>
        </div>
      </article>
    </div>
  </section>


  <!-- Responsabilités -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Rôle
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Responsabilités du conseil</h2>
      <p class="mt-2 leading-7 text-slate-600">
        Cet engagement comprend notamment les responsabilités suivantes:
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {responsabilites.map((r) => (
          <article class="rounded-2xl border border-black/10 bg-white/60 p-5">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white shadow-sm">
              <span aria-hidden="true" class="text-lg">{r.icon}</span>
            </div>
            <h3 class="mt-3 font-black text-slate-900">{r.title}</h3>
            <p class="mt-2 text-sm font-semibold leading-6 text-slate-600">{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>


  <!-- Board members -->
  <section id="ca" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-12">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        2024–2025
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Membres de l'exécutif</h2>
      <p class="mt-2 leading-7 text-slate-600">
        Nous remercions sincèrement nos membres actuels et anciens pour leur engagement et leur précieuse contribution à notre mission!
      </p>

      <div class="mt-6 grid gap-3 md:grid-cols-2">
        {exec.map((m) => (
          <div class="flex items-center gap-4 rounded-2xl border border-black/10 bg-white/60 p-4">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl border border-black/10 bg-white text-lg shadow-sm">
              👤
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-wide text-slate-500">{m.role}</p>
              <p class="mt-0.5 font-black text-slate-900">{m.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Join the board form -->
  <section id="rejoignez" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        Postuler
      </div>
      <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">Se joindre au conseil d'administration</h2>
      <p class="mt-2 leading-7 text-slate-600">
        Remplissez ce formulaire pour soumettre votre candidature au conseil d'administration du Ballon Rouge. Si votre candidature est retenue, une vérification judiciaire sera demandée.
      </p>

      <!-- Netlify pre-render detection form (hidden) -->
      <form
        name="ca-candidature"
        data-netlify
        netlify-honeypot="bot-field"
        enctype="multipart/form-data"
        hidden
      >
        <input type="text"     name="fullName" />
        <input type="email"    name="email" />
        <input type="text"     name="phone" />
        <select name="status"></select>
        <select name="sector"></select>
        <select name="childcareExperience"></select>
        <input type="file"     name="cv" />
        <textarea              name="motivation"></textarea>
        <select name="policeCheck"></select>
        <input type="text"     name="bot-field" />
      </form>

      <!-- Actual visible form -->
      <form
        id="caForm"
        name="ca-candidature"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        enctype="multipart/form-data"
        class="mt-6 grid gap-5"
      >
        <!-- Required hidden fields -->
        <input type="hidden" name="form-name" value="ca-candidature" />

        <!-- Honeypot -->
        <p class="hidden" aria-hidden="true">
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <!-- 1. Nom -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">1. Nom complet <span class="text-red-600">*</span></label>
          <input
            name="fullName"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          />
        </div>

        <!-- 2 & 3. Courriel + Téléphone -->
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="text-sm font-extrabold text-slate-700">2. Adresse courriel <span class="text-red-600">*</span></label>
            <input
              type="email"
              name="email"
              required
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
          <div>
            <label class="text-sm font-extrabold text-slate-700">3. Numéro de téléphone <span class="text-red-600">*</span></label>
            <input
              name="phone"
              required
              class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            />
          </div>
        </div>

        <!-- 4. Statut -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">4. Statut <span class="text-red-600">*</span></label>
          <select
            name="status"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Sélectionnez votre statut</option>
            <option>Parent</option>
            <option>Membre de la communauté</option>
          </select>
        </div>

        <!-- 5. Secteurs -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            5. Travaillez-vous, avez-vous travaillé ou êtes-vous impliqué·e dans l'un des secteurs suivants? <span class="text-red-600">*</span>
          </label>
          <select
            name="sector"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Sélectionnez un secteur</option>
            {sectors.map((s) => <option value={s}>{s}</option>)}
          </select>
        </div>

        <!-- 6. Expérience services de garde -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            6. Avez-vous une expérience et/ou connaissance de l'organisation et du fonctionnement des services de garde d'enfants en Ontario? <span class="text-red-600">*</span>
          </label>
          <select
            name="childcareExperience"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Sélectionnez un niveau</option>
            <option>Non</option>
            <option>Débutant</option>
            <option>Intermédiaire</option>
            <option>Avancé</option>
          </select>
        </div>

        <!-- 7. CV + motivation -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            7. CV et motivations <span class="text-red-600">*</span>
          </label>
          <p class="mt-1 text-xs font-semibold text-slate-500">
            Veuillez joindre votre CV et indiquer vos raisons de motivation à joindre notre conseil d'administration.
          </p>
          <input
            type="file"
            name="cv"
            accept=".pdf,.doc,.docx,.xls,.xlsx"
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm"
          />
          <p class="mt-1 text-xs font-semibold text-slate-400">PDF, DOCX, XLSX — 2 Mo max</p>
          <textarea
            name="motivation"
            required
            class="mt-3 min-h-[140px] w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
            placeholder="Indiquez ici vos raisons de motivation à joindre le conseil d'administration du Ballon Rouge."
          ></textarea>
        </div>

        <!-- 8. Vérification judiciaire -->
        <div>
          <label class="text-sm font-extrabold text-slate-700">
            8. Si votre candidature est retenue, acceptez-vous de vous soumettre à un processus de vérification judiciaire? <span class="text-red-600">*</span>
          </label>
          <select
            name="policeCheck"
            required
            class="mt-2 w-full rounded-2xl border border-black/10 bg-white px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
          >
            <option value="">Sélectionnez une réponse</option>
            <option value="oui">Oui, j'accepte</option>
            <option value="non">Non, je refuse</option>
          </select>
        </div>

        <!-- Submit + status -->
        <div class="space-y-3">
          <button
            type="submit"
            id="caSubmitBtn"
            class="mt-2 inline-flex w-full justify-center rounded-2xl bg-red-700 px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800 disabled:opacity-60 disabled:cursor-not-allowed transition-all"
          >
            Soumettre ma candidature
          </button>

          <!-- Success -->
          <div
            id="caSuccess"
            class="hidden rounded-2xl bg-green-50 border border-green-200 px-5 py-4 text-sm font-semibold text-green-800"
            role="alert"
          >
            ✅ Votre candidature a bien été reçue! Nous vous contacterons si votre profil est retenu.
          </div>

          <!-- Error -->
          <div
            id="caError"
            class="hidden rounded-2xl bg-red-50 border border-red-200 px-5 py-4 text-sm font-semibold text-red-800"
            role="alert"
          >
            ❌ Une erreur s'est produite. Veuillez réessayer ou nous contacter directement via la
            <a href="/contact/" class="underline underline-offset-4">page contact</a>.
          </div>
        </div>

      </form>
    </div>
  </section>


  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-[28px] bg-gradient-to-br from-red-700 to-red-900 p-8 text-center shadow-2xl shadow-red-900/30 md:p-12">
      <p class="text-4xl font-black text-white">🎈</p>
      <h2 class="mt-3 text-2xl font-black text-white md:text-3xl">Merci à nos bénévoles!</h2>
      <p class="mx-auto mt-3 max-w-prose text-base font-semibold leading-7 text-white/80">
        Nous remercions sincèrement nos membres actuels et anciens pour leur engagement et leur précieuse contribution à la mission du Ballon Rouge.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href="#rejoignez"
          class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-extrabold text-red-700 shadow-lg hover:bg-red-50"
        >
          Rejoindre le CA →
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3 text-sm font-extrabold text-white hover:bg-white/10"
        >
          Nous contacter
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function () {
    var form    = document.getElementById('caForm');
    var btn     = document.getElementById('caSubmitBtn');
    var success = document.getElementById('caSuccess');
    var error   = document.getElementById('caError');

    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      btn.disabled    = true;
      btn.textContent = 'Envoi en cours…';
      success.classList.add('hidden');
      error.classList.add('hidden');

      // Use FormData directly (not URLSearchParams) to support file upload
      var data = new FormData(form);

      fetch('/', {
        method: 'POST',
        body: data,
      })
        .then(function (res) {
          if (res.ok) {
            form.reset();
            success.classList.remove('hidden');
            success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          } else {
            throw new Error('Network response was not ok');
          }
        })
        .catch(function () {
          error.classList.remove('hidden');
          error.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        })
        .finally(function () {
          btn.disabled    = false;
          btn.textContent = 'Soumettre ma candidature';
        });
    });
  })();
</script>