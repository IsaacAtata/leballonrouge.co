---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  lang="fr"
  title="404 — Page introuvable | Le Ballon Rouge"
  description="La page que vous cherchez est introuvable. / The page you are looking for could not be found."
>

  <section class="mx-auto flex min-h-[80vh] max-w-4xl flex-col items-center justify-center px-6 py-24 text-center">

    <!-- Big bold 404 number -->
    <div class="relative select-none">
      <p class="text-[9rem] font-black leading-none tracking-tighter text-red-700/10 md:text-[14rem]">
        404
      </p>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-6xl md:text-8xl" aria-hidden="true">🎈</span>
      </div>
    </div>

    <!-- Badge -->
    <div class="mt-8 inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-1.5 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
      Erreur 404 &nbsp;·&nbsp; Error 404
    </div>

    <!-- French -->
    <h1 class="mt-6 text-3xl font-black tracking-tight text-slate-900 md:text-4xl">
      Page introuvable
    </h1>
    <p class="mt-3 max-w-sm text-base font-medium leading-7 text-slate-500">
      La page que vous cherchez n'existe pas ou a été déplacée.
    </p>

    <!-- Divider -->
    <div class="my-8 flex w-full max-w-xs items-center gap-4">
      <div class="h-px flex-1 rounded-full bg-black/10"></div>
      <span class="text-xs font-black uppercase tracking-widest text-slate-300">EN</span>
      <div class="h-px flex-1 rounded-full bg-black/10"></div>
    </div>

    <!-- English -->
    <h2 class="text-2xl font-black tracking-tight text-slate-900 md:text-3xl">
      Page not found
    </h2>
    <p class="mt-3 max-w-sm text-base font-medium leading-7 text-slate-500">
      The page you are looking for does not exist or may have been moved.
    </p>

    <!-- Nav buttons -->
    <div class="mt-12 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-red-700 px-7 py-3.5 text-sm font-extrabold text-white shadow-lg shadow-red-700/25 transition-all hover:bg-red-800 hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
        </svg>
        Accueil · Home
      </a>

      <a
        href="/centres/"
        class="inline-flex items-center justify-center gap-2 rounded-full border border-black/10 bg-white px-7 py-3.5 text-sm font-extrabold text-slate-800 shadow-sm transition-all hover:bg-white/80 hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Centres
      </a>

      <a
        href="/contact/"
        class="inline-flex items-center justify-center gap-2 rounded-full border border-black/10 bg-white px-7 py-3.5 text-sm font-extrabold text-slate-800 shadow-sm transition-all hover:bg-white/80 hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
        Contact
      </a>
    </div>

    <!-- Help text -->
    <p class="mt-12 max-w-sm text-xs font-semibold leading-7 text-slate-400">
      Si vous croyez qu'il s'agit d'une erreur, contactez-nous à
      <a href="mailto:info@ballonrouge.ca" class="text-red-700 underline underline-offset-4 hover:text-red-900">
        info@ballonrouge.ca
      </a>.<br />
      If you believe this is an error, please contact us at
      <a href="mailto:info@ballonrouge.ca" class="text-red-700 underline underline-offset-4 hover:text-red-900">
        info@ballonrouge.ca
      </a>.
    </p>

  </section>

</BaseLayout>