---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const c = {
  city: "Brantford",
  name: "Le Ballon Rouge Brantford",
  address: "60 Clench Ave, Brantford, ON N3T 1B8",
  hours: "Lundi au Vendredi 7h30 — 17h30",
  phone: "519-753-6541",
  phoneTel: "15197536541",
  email: "leballonrougebrantford@cscmonavenir.ca",
  supervisor: "Awatef Belghiti",
  school: "École élémentaire Sainte Marguerite Bourgeoys",
  programs: ["Bambins", "Préscolaires", "Avant et Après école"],
  inscriptionHref: "/inscription/brantford/",
  mapsQuery: encodeURIComponent("60 Clench Ave, Brantford, ON N3T 1B8"),
  googlePlaceUrl: "https://www.google.com/maps/place/Ballon+Rouge+Brantford+Le/@43.1249678,-80.2692262,17z/data=!3m1!5s0x882c66224ef0d12b:0x7c74146ac0ce288b!4m15!1m8!3m7!1s0x882c662250f94ca7:0xa61c9f61580b00a2!2s60+Clench+Ave,+Brantford,+ON+N3T+1B9!3b1!8m2!3d43.1249678!4d-80.2692262!16s%2Fg%2F11c0vpmtmg!3m5!1s0x882c662248959271:0x878929e7f1c7180b!8m2!3d43.1249728!4d-80.2692683!16s%2Fg%2F1hc0sm54k?entry=ttu",

  // 👇 REPLACE "FILENAME1.jpg" etc with your real filenames from:
  // public/assets/images/Staff Brantford/
  staff: [
    { name: "", role: "", photo: "/assets/images/Staff Brantford/IMG_4776.jpg" },
    { name: "", role: "", photo: "/assets/images/Staff Brantford/IMG_6078.jpg" },
    { name: "", role: "", photo: "/assets/images/Staff Brantford/IMG_6094.jpg" },
    { name: "", role: "", photo: "/assets/images/Staff Brantford/IMG_6018.jpg" },
  ],

  // 👇 REPLACE "FILENAME1.jpg" etc with your real filenames from:
  // public/assets/images/Activities - Brantford/
  activities: [
    { src: "/assets/images/Activities - Brantford/FILENAME1.jpg", alt: "Bricolage en groupe" },
    { src: "/assets/images/Activities - Brantford/FILENAME2.jpg", alt: "Jeux extérieurs" },
    { src: "/assets/images/Activities - Brantford/FILENAME3.jpg", alt: "Cercle de lecture" },
    { src: "/assets/images/Activities - Brantford/FILENAME4.jpg", alt: "Activité musicale" },
    { src: "/assets/images/Activities - Brantford/FILENAME5.jpg", alt: "Atelier créatif" },
    { src: "/assets/images/Activities - Brantford/FILENAME6.jpg", alt: "Sortie éducative" },
  ],
};
---

<BaseLayout lang="fr" title={`${c.name} — Le Ballon Rouge`} description={`Découvrez le centre ${c.name} à ${c.city}, en Ontario.`}>

  <section class="mx-auto max-w-6xl px-4 pb-6 pt-8 md:pt-12">
    <a href="/centres/" class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-black uppercase tracking-widest text-slate-700 shadow-sm hover:bg-slate-50">
      ← Retour aux centres
    </a>

    <div class="mt-6 flex flex-wrap items-start justify-between gap-4">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          📍 {c.city}
        </div>
        <h1 class="mt-3 text-3xl font-black tracking-tight md:text-5xl">{c.name}</h1>
        <p class="mt-2 text-sm font-semibold text-slate-500">{c.address} · {c.hours}</p>
      </div>
      <a href={c.inscriptionHref} class="inline-flex items-center justify-center rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800">
        Inscription — {c.city} →
      </a>
    </div>
  </section>

  <!-- Info + Map -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="grid gap-5 md:grid-cols-2">

      <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
        <h3 class="text-lg font-black tracking-tight">Coordonnées</h3>
        <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-700">
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">📍</span><span>{c.address}</span></li>
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">🕐</span><span>{c.hours}</span></li>
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">👩‍🏫</span><span><span class="font-extrabold text-slate-900">Superviseure:</span> {c.supervisor}</span></li>
          <li class="flex items-start gap-3"><span class="mt-0.5 text-base">🏫</span><span><span class="font-extrabold text-slate-900">École:</span> {c.school}</span></li>
        </ul>

        <div class="mt-5 space-y-2">
          <a href={`tel:${c.phoneTel}`} class="flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3 text-sm font-extrabold text-slate-800 hover:bg-white">📞 {c.phone}</a>
          <a href={`mailto:${c.email}`} class="flex items-center gap-3 rounded-2xl border border-black/10 bg-white/60 px-4 py-3 text-sm font-extrabold text-red-700 hover:bg-white">✉️ {c.email}</a>
        </div>

        <div class="mt-5">
          <p class="text-sm font-extrabold text-slate-900">Programmes offerts</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {c.programs.map((p) => (
              <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1.5 text-xs font-extrabold text-slate-700">{p}</span>
            ))}
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href={c.inscriptionHref} class="inline-flex items-center justify-center rounded-full bg-red-700 px-5 py-2.5 text-sm font-extrabold text-white shadow-lg shadow-red-700/20 hover:bg-red-800">S'inscrire →</a>
          <a href="/programmes/" class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white">Nos programmes</a>
          <a href="/contact/" class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white/80 px-5 py-2.5 text-sm font-extrabold text-slate-800 shadow-sm hover:bg-white">Nous contacter</a>
        </div>
      </article>

      <div class="rounded-[28px] border border-black/10 bg-white/70 p-3 shadow-xl shadow-black/5">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-black/10 bg-white">
          <iframe title={`Carte — Centre ${c.city}`} class="h-full w-full" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src={`https://www.google.com/maps?q=${c.mapsQuery}&output=embed`} />
        </div>
        <div class="mt-3 flex flex-wrap gap-2 px-2 pb-2">
          <a href={c.googlePlaceUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80">🗺️ Ouvrir dans Google Maps</a>
          <a href={`https://www.google.com/maps/dir/?api=1&destination=${c.mapsQuery}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-black/10 bg-white px-4 py-2 text-xs font-extrabold shadow-sm hover:bg-white/80">🧭 Obtenir l'itinéraire</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Staff -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <h2 class="mb-1 text-lg font-black tracking-tight">Notre équipe</h2>
    <p class="mb-6 text-sm font-medium text-slate-500">Des éducatrices et éducateurs qualifiés, dévoués au bien-être de chaque enfant.</p>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      {c.staff.map((s) => (
        <div class="rounded-[24px] border border-black/10 bg-white/70 p-4 text-center shadow-sm">
          <div class="aspect-square w-full overflow-hidden rounded-2xl bg-slate-100">
            <img src={s.photo} alt={s.name} class="h-full w-full object-cover" loading="lazy" />
          </div>
          <p class="mt-3 text-sm font-extrabold text-slate-900">{s.name}</p>
          <p class="text-xs font-semibold text-slate-500">{s.role}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Activities gallery -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <h2 class="mb-1 text-lg font-black tracking-tight">La vie au centre</h2>
    <p class="mb-6 text-sm font-medium text-slate-500">Un aperçu des activités quotidiennes de nos petits à {c.city}.</p>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      {c.activities.map((img) => (
        <div class="aspect-square overflow-hidden rounded-2xl border border-black/10 bg-slate-100 shadow-sm">
          <img src={img.src} alt={img.alt} class="h-full w-full object-cover" loading="lazy" />
        </div>
      ))}
    </div>
  </section>

</BaseLayout>