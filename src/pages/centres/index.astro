---
import BaseLayout from "../../layouts/BaseLayout.astro";

const centres = [
  {
    slug: "hamilton",
    city: "Hamilton",
    name: "Le Ballon Rouge Hamilton",
    address: "135 Bendamere Ave, Hamilton, ON L9C 1N4",
    blurb: "Situé près de l'École Mon Seigneur de Laval, notre centre accueille bambins et préscolaires dans un environnement bilingue chaleureux et sécuritaire.",
  },
  {
    slug: "brantford",
    city: "Brantford",
    name: "Le Ballon Rouge Brantford",
    address: "60 Clench Ave, Brantford, ON N3T 1B8",
    blurb: "Intégré à l'École Sainte Marguerite Bourgeoys, ce centre offre une transition en douceur entre la garderie et le milieu scolaire francophone.",
  },
];
---

<BaseLayout lang="fr" title="Centres — Le Ballon Rouge" description="Découvrez les deux centres francophones du Ballon Rouge à Hamilton et Brantford, en Ontario.">

  <section class="mx-auto max-w-6xl px-4 pb-10 pt-8 md:pt-12">
    <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-1.5 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
      Ontario · 2 centres
    </div>
    <h1 class="mt-4 text-3xl font-black tracking-tight md:text-5xl">Nos centres</h1>
    <p class="mt-3 max-w-prose text-base font-medium leading-7 text-slate-600 md:text-lg">
      Deux centres francophones en Ontario — Hamilton et Brantford — offrant des programmes agréés pour les bambins, préscolaires et le parascolaire.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="grid gap-6 md:grid-cols-2">
      {centres.map((c) => (
        <a
          href={`/centres/${c.slug}/`}
          class="group rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 transition-all hover:-translate-y-1 hover:shadow-2xl md:p-8"
        >
          <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
            📍 {c.city}
          </div>
          <h2 class="mt-3 text-2xl font-black tracking-tight">{c.name}</h2>
          <p class="mt-1 text-sm font-semibold text-slate-500">{c.address}</p>
          <p class="mt-3 text-sm font-medium leading-6 text-slate-600">{c.blurb}</p>
          <span class="mt-4 inline-flex items-center gap-2 text-sm font-extrabold text-red-700">
            Voir le centre <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>