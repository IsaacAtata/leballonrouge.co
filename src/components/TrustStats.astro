---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).trueStats;

const stats = [
  {
    value: "1986",
    label:  t.stat1,
    badge:  lang === "fr" ? "En service depuis" : "Serving since",
  },
  {
    value: "2",
    label:  t.stat2,
    badge:  lang === "fr" ? "Centres francophones" : "Francophone centres",
  },
  {
    value: "100%",
    label:  t.stat3,
    badge:  lang === "fr" ? "Agréé Ministère" : "Ministry licensed",
  },
  {
    value: "FR",
    label:  t.stat4,
    badge:  lang === "fr" ? "Immersion quotidienne" : "Daily immersion",
  },
];
---

<section class="mx-auto max-w-6xl px-4 py-16">

  <!-- Section heading -->
  <p class="text-center text-xs font-extrabold uppercase tracking-[0.22em] text-red-700">
    {lang === "fr" ? "Le Ballon Rouge en chiffres" : "Le Ballon Rouge by the numbers"}
  </p>

  <!-- Stats grid -->
  <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
    {stats.map((s) => (
      <div class="group relative flex flex-col items-center overflow-hidden rounded-[28px] border border-black/5 bg-white px-5 py-8 text-center shadow-lg shadow-black/5 transition hover:shadow-xl hover:-translate-y-1 duration-200">

        <!-- Soft red glow behind number -->
        <div class="pointer-events-none absolute -top-6 left-1/2 h-24 w-24 -translate-x-1/2 rounded-full bg-red-100 opacity-60 blur-2xl"></div>

        <!-- Badge pill -->
        <span class="relative mb-4 inline-flex items-center rounded-full border border-black/5 bg-slate-50 px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest text-slate-400">
          {s.badge}
        </span>

        <!-- Big number -->
        <div class="relative text-5xl font-black leading-none tracking-tight text-red-700 md:text-6xl">
          {s.value}
        </div>

        <!-- Divider -->
        <div class="mt-4 h-[2px] w-8 rounded-full bg-red-100"></div>

        <!-- Label -->
        <p class="mt-3 text-sm font-semibold leading-snug text-slate-600">
          {s.label}
        </p>
      </div>
    ))}
  </div>

</section>