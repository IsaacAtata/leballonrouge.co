---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).faqAccordion;
const base = lang === "en" ? "/en" : "";

const {
  title = t.title,
  subtitle = t.subtitle,
  items = t.items,
} = Astro.props;

const uid = `faq-${Math.random().toString(36).slice(2)}`;
---

<section class="mx-auto max-w-6xl px-4 pb-12">

  <!-- Section header -->
  <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="text-2xl font-black tracking-tight md:text-3xl">{title}</h2>
      <p class="mt-2 max-w-2xl text-slate-600 md:text-lg">{subtitle}</p>
    </div>

    <!-- CTA button -->
    <a
      href={`${base}/espace-parents/`}
      class="inline-flex h-fit items-center justify-center rounded-full border border-black/10 bg-white px-5 py-2.5 text-sm font-extrabold shadow-sm hover:bg-white/80"
    >
      {t.cta}
    </a>
  </div>

  <!-- FAQ Accordion -->
  <div class="faq-accordion mt-8 grid gap-5">
    {items.map((item: { q: string; a: string }, i: number) => (
      <details
        class="faq-item group rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-7"
        name={uid}
        open={i === 0}
      >
        <summary class="faq-summary flex list-none items-start justify-between gap-5">
          <span class="pr-2 text-base font-black text-slate-900 md:text-lg">
            {item.q}
          </span>

          <span
            aria-hidden="true"
            class="faq-icon mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-black/10 bg-white/80 text-red-700 shadow-sm"
            title={t.openLabel}
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </span>
        </summary>

        <div class="faq-content mt-4 leading-7 text-slate-600 md:text-[1.05rem]">
          {item.a}
        </div>
      </details>
    ))}
  </div>

</section>
