---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).faqAccordion;
const base = lang === "en" ? "/en" : "";

const {
  title = t.title,
  subtitle = t.subtitle,
  items = t.items,
} = Astro.props;

const uid = `faq-${Math.random().toString(36).slice(2)}`;
---

<section id="faq" class="scroll-mt-28 mx-auto max-w-4xl px-4 pb-12">

  <!-- Section header -->
  <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        FAQ
      </div>
      <h2 class="mt-3 text-2xl font-black tracking-tight md:text-3xl">{title}</h2>
      <p class="mt-2 max-w-2xl text-slate-600 md:text-lg">{subtitle}</p>
    </div>
    <a
      href={`${base}/espace-parents/`}
      class="inline-flex h-fit w-fit items-center justify-center rounded-full border border-black/10 bg-white px-5 py-2.5 text-sm font-extrabold shadow-sm hover:bg-white/80"
    >
      {t.cta}
    </a>
  </div>

  <!-- FAQ items -->
  <div class="mt-6 flex flex-col gap-3 md:mt-8">
    {items.map((item: { q: string; a: string }, i: number) => (
      <details
        class="faq-item group overflow-hidden rounded-2xl border border-black/8 bg-white shadow-sm shadow-black/5"
        name={uid}
        open={i === 0}
      >

        <!-- Question row -->
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 border-b border-transparent px-5 py-5 transition-colors duration-200 group-open:border-black/8 group-open:bg-red-50/60 md:gap-4 md:px-7 md:py-6">
          <div class="flex items-center gap-3">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-red-700/10 text-xs font-black text-red-700 md:h-8 md:w-8">
              {i + 1}
            </span>
            <span class="text-sm font-black text-slate-900 md:text-[1.05rem] lg:text-lg">
              {item.q}
            </span>
          </div>
          <span
            aria-hidden="true"
            class="faq-icon ml-1 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-black/10 bg-white text-red-700 shadow-sm transition-transform duration-300 group-open:rotate-180 md:h-10 md:w-10"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 md:h-5 md:w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </span>
        </summary>

        <!-- Answer body — wrapped for animation -->
        <div class="faq-body overflow-hidden">
          <div class="px-5 py-5 md:px-7 md:py-6">
            <p class="mb-2 text-[0.65rem] font-black uppercase tracking-widest text-red-700/70 md:text-[0.7rem]">
              {lang === "en" ? "Answer" : "Réponse"}
            </p>
            <p class="text-sm leading-7 text-slate-600 md:text-[1.02rem] md:leading-8">
              {item.a}
            </p>
          </div>
        </div>

      </details>
    ))}
  </div>

</section>

<script>
  document.querySelectorAll<HTMLDetailsElement>("details.faq-item").forEach((details) => {
    const summary = details.querySelector("summary")!;

    summary.addEventListener("click", (e) => {
      e.preventDefault();

      if (details.open) {
        const body = details.querySelector<HTMLElement>(".faq-body")!;
        body.style.gridTemplateRows = "0fr";
        body.addEventListener(
          "transitionend",
          () => { details.removeAttribute("open"); },
          { once: true }
        );
      } else {
        details.setAttribute("open", "");
        const body = details.querySelector<HTMLElement>(".faq-body")!;
        body.getBoundingClientRect();
        body.style.gridTemplateRows = "1fr";
      }
    });
  });
</script>