---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).storyBlock;
const base = lang === "en" ? "/en" : "";
---

<!-- Story paragraph -->
<section class="mx-auto max-w-6xl px-4 pb-10">
  <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="max-w-3xl">
        <h2 class="text-xl font-black tracking-tight md:text-2xl">{t.title}</h2>
        <p class="mt-3 leading-7 text-slate-600">{t.body}</p>
      </div>

      <a
        href={`${base}/qui-sommes-nous/`}
        class="mt-2 inline-flex h-fit items-center justify-center rounded-full border border-black/10 bg-white px-5 py-2.5 text-sm font-extrabold shadow-sm hover:bg-white/80"
      >
        {t.learnMore}
      </a>
    </div>
  </div>
</section>

<!-- Vision / Mission / Values -->
<section class="mx-auto max-w-6xl px-4 pb-10">
  <div class="grid gap-5 md:grid-cols-3">

    <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5">
      <h3 class="text-lg font-black">{t.visionTitle}</h3>
      <p class="mt-2 leading-7 text-slate-600">{t.visionBody}</p>
    </article>

    <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5">
      <h3 class="text-lg font-black">{t.missionTitle}</h3>
      <p class="mt-2 leading-7 text-slate-600">{t.missionBody}</p>
    </article>

    <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5">
      <h3 class="text-lg font-black">{t.valuesTitle}</h3>
      <ul class="mt-2 space-y-2 font-bold text-slate-700">
        {t.values.map((v) => <li>{v}</li>)}
      </ul>
    </article>

  </div>
</section>