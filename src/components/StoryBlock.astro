---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).storyBlock;
const base = lang === "en" ? "/en" : "";
---

<!-- Story paragraph -->
<section id="notre-histoire" class="scroll-mt-28 mx-auto max-w-6xl px-4 pb-10">
  <div class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5 md:p-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
          {lang === "en" ? "Our story" : "Notre histoire"}
        </div>
        <h2 class="mt-3 text-xl font-black tracking-tight md:text-2xl">{t.title}</h2>
        <p class="mt-3 leading-7 text-slate-600">{t.body}</p>
      </div>

      <a
        href={`${base}/qui-sommes-nous/`}
        class="mt-2 inline-flex h-fit items-center justify-center rounded-full border border-black/10 bg-white px-5 py-2.5 text-sm font-extrabold shadow-sm hover:bg-white/80"
      >
        {t.learnMore}
      </a>
    </div>
  </div>
</section>

<!-- Vision / Mission / Values -->
<section class="mx-auto max-w-6xl px-4 pb-10">
  <div class="grid gap-5 md:grid-cols-3">

    <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        🔭 {lang === "en" ? "Vision" : "Vision"}
      </div>
      <h3 class="mt-3 text-lg font-black">{t.visionTitle}</h3>
      <p class="mt-2 leading-7 text-slate-600">{t.visionBody}</p>
    </article>

    <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        🎯 {lang === "en" ? "Mission" : "Mission"}
      </div>
      <h3 class="mt-3 text-lg font-black">{t.missionTitle}</h3>
      <p class="mt-2 leading-7 text-slate-600">{t.missionBody}</p>
    </article>

    <article class="rounded-[28px] border border-black/10 bg-white/70 p-6 shadow-xl shadow-black/5">
      <div class="inline-flex items-center gap-2 rounded-full bg-red-50 px-3 py-1 text-xs font-black uppercase tracking-widest text-red-700 ring-1 ring-red-100">
        💎 {lang === "en" ? "Values" : "Valeurs"}
      </div>
      <h3 class="mt-3 text-lg font-black">{t.valuesTitle}</h3>
      <ul class="mt-3 space-y-2">
        {t.values.map((v: string) => (
          <li class="flex items-center gap-2 text-sm font-semibold text-slate-700">
            <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-red-700/10 text-[10px] font-black text-red-700">✓</span>
            {v}
          </li>
        ))}
      </ul>
    </article>

  </div>
</section>