---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

interface Props {
  lang?: Lang;
}

const { lang = "fr" } = Astro.props;
const t = useTranslations(lang).nav;
const base = lang === "en" ? "/en" : "";
---

<header class="sticky top-0 z-50 border-b border-black/10 bg-white/95 backdrop-blur-xl">
  <div class="mx-auto max-w-screen-2xl px-2 py-4">
    <div class="flex items-center justify-between">

      <!-- Logo -->
      <a href={`${base}/`} class="flex items-center gap-3">
        <img
          src="/assets/images/LBR_No_Name.png"
          alt="Le Ballon Rouge"
          class="h-11 w-11 rounded-full object-contain bg-white shadow-lg"
          loading="eager"
          decoding="async"
        />
        <div>
          <p class="text-base font-black text-slate-900">Le Ballon Rouge</p>
          <p class="text-xs font-semibold text-slate-600">{t.tagline}</p>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:block" aria-label={t.ariaNav}>
        <div class="flex items-center gap-2">

          <!-- About -->
          <div class="nav-group">
            <a href={`${base}/qui-sommes-nous/`} class="nav-trigger px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
              {t.about}
              <span class="arrow" aria-hidden="true">▾</span>
            </a>
            <div class="nav-dropdown">
              <a href={`${base}/qui-sommes-nous/#vmv`} class="dropdown-item">{t.aboutDropdown.vmv}</a>
              <a href={`${base}/qui-sommes-nous/#partenariats`} class="dropdown-item">{t.aboutDropdown.partnerships}</a>
              <a href={`${base}/qui-sommes-nous/#temoignages`} class="dropdown-item">{t.aboutDropdown.testimonials}</a>
            </div>
          </div>

          <!-- Inscription -->
          <div class="nav-group">
            <a href={`${base}/inscription/`} class="nav-trigger px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
              {t.inscription}
              <span class="arrow" aria-hidden="true">▾</span>
            </a>
            <div class="nav-dropdown">
              <a href={`${base}/inscription/hamilton/`} class="dropdown-item">Le Ballon Rouge — Hamilton</a>
              <a href={`${base}/inscription/brantford/`} class="dropdown-item">Le Ballon Rouge — Brantford</a>
            </div>
          </div>

          <!-- Parents -->
          <div class="nav-group">
            <button type="button" class="nav-trigger px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
              {t.parents}
              <span class="arrow" aria-hidden="true">▾</span>
            </button>
            <div class="nav-dropdown">
              <a href={`${base}/espace-parents/#guide`} class="dropdown-item">{t.parentsDropdown.guide}</a>
              <a href={`${base}/espace-parents/#frais`} class="dropdown-item">{t.parentsDropdown.fees}</a>
              <a href={`${base}/espace-parents/#menu`} class="dropdown-item">{t.parentsDropdown.menu}</a>
              <a href={`${base}/espace-parents/#ressources`} class="dropdown-item">{t.parentsDropdown.resources}</a>
            </div>
          </div>

          <!-- Programmes -->
          <div class="nav-group">
            <a href={`${base}/programmes/`} class="nav-trigger px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
              {t.programmes}
              <span class="arrow" aria-hidden="true">▾</span>
            </a>
            <div class="nav-dropdown">
              <a href={`${base}/programmes/#enonce`} class="dropdown-item">{t.programmesDropdown.statement}</a>
              <a href={`${base}/programmes/#qualite`} class="dropdown-item">{t.programmesDropdown.quality}</a>
              <a href={`${base}/programmes/#evenements`} class="dropdown-item">{t.programmesDropdown.events}</a>
            </div>
          </div>

          <!-- Personnel -->
          <div class="nav-group">
            <a href={`${base}/personnel/`} class="nav-trigger px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
              {t.personnel}
              <span class="arrow" aria-hidden="true">▾</span>
            </a>
            <div class="nav-dropdown">
              <a href={`${base}/personnel/#reconnaissances`} class="dropdown-item">{t.personnelDropdown.recognition}</a>
              <a href={`${base}/personnel/#emplois`} class="dropdown-item">{t.personnelDropdown.jobs}</a>
              <a href={`${base}/personnel/#rejoignez`} class="dropdown-item">{t.personnelDropdown.join}</a>
            </div>
          </div>

          <!-- Gouvernance -->
          <a href={`${base}/gouvernance/`} class="px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
            {t.gouvernance}
          </a>

          <!-- Centres -->
          <div class="nav-group">
            <a href={`${base}/centres/`} class="px-3 py-2 text-sm font-extrabold text-slate-800 hover:text-red-700">
              {t.centres}
              <span class="arrow" aria-hidden="true">▾</span>
            </a>
            <div class="nav-dropdown">
              <a href={`${base}/centres/brantford/`} class="dropdown-item">Le Ballon Rouge Brantford</a>
              <a href={`${base}/centres/hamilton/`} class="dropdown-item">Le Ballon Rouge Hamilton</a>
            </div>
          </div>

        </div>
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-4">

        <!-- Language switcher -->
        <div class="nav-group">
          <button
            type="button"
            class="nav-trigger lang-trigger"
            id="langToggle"
            aria-haspopup="true"
            aria-expanded="false"
            aria-label={t.ariaLang}
          >
            <span class="lang-current" data-lang={lang}>
              <img src={`/assets/flags/${lang}.svg`} alt={t.langLabel} class="w-5 h-4 mr-1 rounded-sm" />
              <span>{t.langLabel}</span>
            </span>
            <span class="arrow" aria-hidden="true">▾</span>
          </button>

          <div class="nav-dropdown lang-dropdown">
            {/* hrefs are set dynamically by the script below */}
            <a id="lang-opt-fr" href="/" class="dropdown-item lang-option" data-lang="fr">
              <img src="/assets/flags/fr.svg" alt="Français" class="w-5 h-4 mr-2 rounded-sm" />
              Français
            </a>
            <a id="lang-opt-en" href="/en/" class="dropdown-item lang-option" data-lang="en">
              <img src="/assets/flags/en.svg" alt="English" class="w-5 h-4 mr-2 rounded-sm" />
              English
            </a>
          </div>
        </div>

        <!-- CTA -->
        <a
          href={`${base}/inscription/`}
          class="hidden md:inline-flex items-center gap-2 rounded-full bg-red-700 px-4 py-2.5 text-sm font-extrabold text-white hover:bg-red-800 shadow-lg shadow-red-700/25"
        >
          {t.cta}
          <span aria-hidden="true">→</span>
        </a>

        <!-- Mobile toggle -->
        <button
          id="menuBtn"
          type="button"
          class="lg:hidden rounded-full border border-slate-200 bg-white px-3 py-2 text-xs font-extrabold hover:bg-slate-50"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          {t.menu}
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="hidden border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-4">
      <nav class="grid grid-cols-2 gap-2">
        <a href={`${base}/qui-sommes-nous/`} class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.about}</a>
        <a href={`${base}/inscription/`}     class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.inscription}</a>
        <a href={`${base}/espace-parents/`}  class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.parents}</a>
        <a href={`${base}/centres/`}         class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.centres}</a>
        <a href={`${base}/programmes/`}      class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.programmes}</a>
        <a href={`${base}/personnel/`}       class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.personnel}</a>
        <a href={`${base}/gouvernance/`}     class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">{t.gouvernance}</a>
        <a href={`${base}/contact/`}         class="rounded-lg p-3 text-sm font-bold hover:bg-slate-50">Contact</a>
      </nav>
    </div>
  </div>

</header>

<script>
  // ── Language switcher: stay on the same page ───────────────────
  (function () {
    const path  = window.location.pathname;
    const hash  = window.location.hash;
    const isEN  = path.startsWith("/en/") || path === "/en";

    const frPath = isEN
      ? (path.replace(/^\/en/, "") || "/") + hash
      : path + hash;

    const enPath = isEN
      ? path + hash
      : "/en" + path + hash;

    const optFR = document.getElementById("lang-opt-fr") as HTMLAnchorElement | null;
    const optEN = document.getElementById("lang-opt-en") as HTMLAnchorElement | null;

    if (optFR) optFR.href = frPath;
    if (optEN) optEN.href = enPath;
  })();

  // ── Mobile menu toggle ─────────────────────────────────────────
  const menuBtn    = document.getElementById("menuBtn");
  const mobileMenu = document.getElementById("mobileMenu");

  menuBtn?.addEventListener("click", () => {
    const isNowOpen = !mobileMenu?.classList.toggle("hidden");
    menuBtn.setAttribute("aria-expanded", String(isNowOpen));
  });
</script>