---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).solidInfoCards;
const base = lang === "en" ? "/en" : "";
---

<section class="mx-auto max-w-7xl px-4 py-16">
  <div class="mb-12 text-center">
    <h2 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900 mb-4">
      {t.sectionTitle}
    </h2>
    <p class="max-w-2xl mx-auto text-xl text-slate-600 leading-relaxed">
      {t.sectionSubtitle}
    </p>
  </div>

  <div class="grid gap-8 md:grid-cols-3">

    <!-- Card 1 -->
    <div class="solid-card group">
      <div class="tag-badge mb-6">🌍 {t.card1.tag}</div>
      <h3 class="text-2xl font-black text-slate-900 mb-4 group-hover:text-red-700 transition-colors">
        {t.card1.title}
      </h3>
      <p class="text-lg text-slate-600 leading-relaxed mb-8">{t.card1.body}</p>
      <a href={`${base}/programmes/`} class="inline-flex items-center gap-2 font-bold text-red-700 hover:text-red-900">
        {t.card1.link}
      </a>
    </div>

    <!-- Card 2 -->
    <div class="solid-card group">
      <div class="tag-badge mb-6">👨‍👩‍👧‍👦 {t.card2.tag}</div>
      <h3 class="text-2xl font-black text-slate-900 mb-4 group-hover:text-red-700 transition-colors">
        {t.card2.title}
      </h3>
      <p class="text-lg text-slate-600 leading-relaxed mb-8">{t.card2.body}</p>
      <a href={`${base}/centres/`} class="inline-flex items-center gap-2 font-bold text-red-700 hover:text-red-900">
        {t.card2.link}
      </a>
    </div>

    <!-- Card 3 -->
    <div class="solid-card group">
      <div class="tag-badge mb-6">🍎 {t.card3.tag}</div>
      <h3 class="text-2xl font-black text-slate-900 mb-4 group-hover:text-red-700 transition-colors">
        {t.card3.title}
      </h3>
      <p class="text-lg text-slate-600 leading-relaxed mb-8">{t.card3.body}</p>
      <a href={`${base}/espace-parents/`} class="inline-flex items-center gap-2 font-bold text-red-700 hover:text-red-900">
        {t.card3.link}
      </a>
    </div>

  </div>
</section>