---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).footer;
const isEn = lang === "en";
const base = isEn ? "/en" : "";

// Detect current page path to highlight active footer link
const currentPath = Astro.url.pathname;
---

<footer class="border-t border-black/10 bg-[#171717] text-white">
  <div class="mx-auto max-w-7xl px-4 py-14">

    <!-- Top row -->
    <div class="grid gap-10 lg:grid-cols-4">

      <!-- Brand / about -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3">
          <img
            src="/assets/images/LBR_No_Name.png"
            alt="Le Ballon Rouge"
            class="h-11 w-11 rounded-full object-contain bg-white shadow-lg"
            loading="eager"
            decoding="async"
          />
          <div class="leading-tight">
            <p class="text-lg font-extrabold">{t.brandName}</p>
            <p class="text-sm font-semibold text-white/70">{t.brandSubtitle}</p>
          </div>
        </div>

        <p class="mt-4 text-white/70 leading-7">{t.description}</p>

        <!-- Social links -->
        <div class="mt-6">
          <p class="text-sm font-black uppercase tracking-wider text-white/60">
            {t.socialTitle}
          </p>
          <div class="mt-3 flex flex-wrap gap-2">

            <!-- Facebook -->
            <a href="#" aria-label="Facebook" class="footer-social-pill">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
              </svg>
              Facebook
            </a>

            <!-- Instagram -->
            <a href="#" aria-label="Instagram" class="footer-social-pill">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              Instagram
            </a>

            <!-- YouTube -->
            <a href="#" aria-label="YouTube" class="footer-social-pill">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              YouTube
            </a>

          </div>
        </div>
      </div>

      <!-- Quick links — active page highlighted with red dot -->
      <div>
        <p class="text-sm font-black uppercase tracking-wider text-white/60">
          {t.quickLinksTitle}
        </p>

        <ul class="mt-4 space-y-1">
          {[
            { href: `${base}/`,                 label: t.links.home        },
            { href: `${base}/programmes/`,      label: t.links.programmes  },
            { href: `${base}/centres/`,         label: t.links.centres     },
            { href: `${base}/qui-sommes-nous/`, label: t.links.about       },
            { href: `${base}/inscription/`,     label: t.links.inscription },
            { href: `${base}/espace-parents/`,  label: t.links.parents     },
            { href: `${base}/personnel/`,       label: t.links.personnel   },
            { href: `${base}/gouvernance/`,     label: t.links.gouvernance },
            { href: `${base}/contact/`,         label: t.links.contact     },
          ].map(({ href, label }) => {
            // Homepage needs exact match; all other pages use startsWith
            const isActive = href === `${base}/`
              ? currentPath === `${base}/` || currentPath === "/"
              : currentPath.startsWith(href);

            return (
              <li>
                <a
                  href={href}
                  class={`footer-nav-link ${isActive ? "footer-nav-active" : ""}`}
                  aria-current={isActive ? "page" : undefined}
                >
                  {/* Red dot — hidden by default, visible on active page */}
                  <span class="footer-nav-dot" aria-hidden="true"></span>
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Centres contact -->
      <div class="lg:col-span-2">
        <p class="text-sm font-black uppercase tracking-wider text-white/60">
          {t.contactTitle}
        </p>

        <div class="mt-4 grid gap-5 md:grid-cols-2">

          <!-- Hamilton -->
          <div class="contact-card rounded-3xl border border-white/10 bg-white/5 p-6 transition-colors hover:bg-white/8">
            <div class="flex items-center gap-2 mb-3">
              <!-- Location pin -->
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-red-500 shrink-0" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <p class="text-lg font-extrabold">{t.hamiltonTitle}</p>
            </div>
            <p class="text-white/70 leading-7 text-sm">
              135 Bendamere Ave<br />
              Hamilton, ON L9C 1N4
            </p>

            <div class="mt-3 space-y-2">
              <!-- Phone -->
              <p class="flex items-center gap-2 text-white/80 font-semibold text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-white/40 shrink-0" aria-hidden="true">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
                <a class="hover:text-white underline underline-offset-4" href="tel:+19053838371">905-383-8371</a>
              </p>
              <!-- Email -->
              <p class="flex items-start gap-2 text-white/80 font-semibold text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-white/40 shrink-0 mt-0.5" aria-hidden="true">
                  <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
                <a class="hover:text-white underline underline-offset-4 break-all" href="mailto:leballonrouge@cscmonavenir.ca">
                  leballonrouge@cscmonavenir.ca
                </a>
              </p>
              <!-- Hours -->
              <p class="flex items-center gap-2 text-white/70 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-white/40 shrink-0" aria-hidden="true">
                  <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
                </svg>
                {t.hoursHamilton}
              </p>
            </div>

            <a href={`${base}/centres/#hamilton`} class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-red-700 px-4 py-2 text-sm font-extrabold hover:bg-red-800 transition-colors">
              {t.seeOnMap}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </a>
          </div>

          <!-- Brantford -->
          <div class="contact-card rounded-3xl border border-white/10 bg-white/5 p-6 transition-colors hover:bg-white/8">
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-red-500 shrink-0" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <p class="text-lg font-extrabold">{t.brantfordTitle}</p>
            </div>
            <p class="text-white/70 leading-7 text-sm">
              60 Clench Ave<br />
              Brantford, ON N3T 1B8
            </p>

            <div class="mt-3 space-y-2">
              <!-- Phone -->
              <p class="flex items-center gap-2 text-white/80 font-semibold text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-white/40 shrink-0" aria-hidden="true">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
                <a class="hover:text-white underline underline-offset-4" href="tel:+15197536541">519-753-6541</a>
              </p>
              <!-- Email -->
              <p class="flex items-start gap-2 text-white/80 font-semibold text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-white/40 shrink-0 mt-0.5" aria-hidden="true">
                  <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
                <a class="hover:text-white underline underline-offset-4 break-all" href="mailto:leballonrougebrantford@cscmonavenir.ca">
                  leballonrougebrantford@cscmonavenir.ca
                </a>
              </p>
              <!-- Hours -->
              <p class="flex items-center gap-2 text-white/70 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-white/40 shrink-0" aria-hidden="true">
                  <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
                </svg>
                {t.hoursBrantford}
              </p>
            </div>

            <a href={`${base}/centres/#brantford`} class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-red-700 px-4 py-2 text-sm font-extrabold hover:bg-red-800 transition-colors">
              {t.seeOnMap}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </a>
          </div>

        </div>

        <!-- Newsletter -->
        <div class="mt-6 rounded-3xl border border-white/10 bg-white/5 p-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-lg font-extrabold">{t.newsletterTitle}</p>
              <p class="mt-1 text-white/70 text-sm">{t.newsletterDesc}</p>
            </div>
            <form class="flex w-full max-w-md gap-2" onsubmit="event.preventDefault(); alert('Merci! (Demo)');">
              <label class="sr-only" for="newsletterEmail">{t.newsletterEmailLabel}</label>
              <input
                id="newsletterEmail"
                type="email"
                required
                class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-red-500"
                placeholder={t.newsletterEmailPlaceholder}
              />
              <button class="rounded-2xl bg-red-700 px-5 py-3 font-extrabold hover:bg-red-800 transition-colors shrink-0">
                {t.newsletterSubmit}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-8 md:flex-row md:items-center md:justify-between">
      <p class="text-sm text-white/60">
        © <span id="year"></span> {t.brandName}. {t.bottomRights}.
      </p>
      <div class="flex flex-wrap gap-4 text-sm font-semibold text-white/70">
        <a href="#" class="hover:text-white transition-colors">{t.privacy}</a>
        <a href="#" class="hover:text-white transition-colors">{t.terms}</a>
        <a href={`${base}/inscription/`} class="hover:text-white transition-colors">{t.requestSpot}</a>
      </div>
    </div>

  </div>

  <script is:inline>
    const yearEl = document.getElementById('year');
    if (yearEl) yearEl.textContent = String(new Date().getFullYear());
  </script>
</footer>