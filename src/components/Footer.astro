---
import { useTranslations } from "../i18n";
import type { Lang } from "../i18n";

const { lang = "fr" } = Astro.props as { lang?: Lang };
const t = useTranslations(lang).footer;
const isEn = lang === "en";
const base = isEn ? "/en" : "";
---

<footer class="border-t border-black/10 bg-[#171717] text-white">
  <div class="mx-auto max-w-7xl px-4 py-14">

    <!-- Top row -->
    <div class="grid gap-10 lg:grid-cols-4">

      <!-- Brand / about -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3">
          <span class="h-11 w-11 rounded-full bg-gradient-to-b from-red-500 via-red-600 to-red-800 shadow-lg shadow-red-600/20"></span>
          <div class="leading-tight">
            <p class="text-lg font-extrabold">
              {t.brandName}
            </p>
            <p class="text-sm font-semibold text-white/70">
              {t.brandSubtitle}
            </p>
          </div>
        </div>

        <p class="mt-4 text-white/70 leading-7">
          {t.description}
        </p>

        <!-- Social -->
        <div class="mt-6">
          <p class="text-sm font-black uppercase tracking-wider text-white/60">
            {t.socialTitle}
          </p>
          <div class="mt-3 flex flex-wrap gap-3">
            <a href="#" class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-extrabold hover:bg-white/15">
              <span aria-hidden="true">f</span> Facebook
            </a>
            <a href="#" class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-extrabold hover:bg-white/15">
              <span aria-hidden="true">◎</span> Instagram
            </a>
            <a href="#" class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-extrabold hover:bg-white/15">
              <span aria-hidden="true">▶</span> YouTube
            </a>
          </div>
          <p class="mt-2 text-xs text-white/45">
            {t.socialNote}
          </p>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <p class="text-sm font-black uppercase tracking-wider text-white/60">
          {t.quickLinksTitle}
        </p>
        <ul class="mt-4 space-y-2 text-white/80 font-semibold">
          <li><a class="hover:text-white" href={`${base}/`}>{t.links.home}</a></li>
          <li><a class="hover:text-white" href={`${base}/programmes/`}>{t.links.programmes}</a></li>
          <li><a class="hover:text-white" href={`${base}/centres/`}>{t.links.centres}</a></li>
          <li><a class="hover:text-white" href={`${base}/qui-sommes-nous/`}>{t.links.about}</a></li>
          <li><a class="hover:text-white" href={`${base}/inscription/`}>{t.links.inscription}</a></li>
          <li><a class="hover:text-white" href={`${base}/espace-parents/`}>{t.links.parents}</a></li>
          <li><a class="hover:text-white" href={`${base}/personnel/`}>{t.links.personnel}</a></li>
          <li><a class="hover:text-white" href={`${base}/gouvernance/`}>{t.links.gouvernance}</a></li>
          <li><a class="hover:text-white" href={`${base}/contact/`}>{t.links.contact}</a></li>
        </ul>
      </div>

      <!-- Centres contact -->
      <div class="lg:col-span-2">
        <p class="text-sm font-black uppercase tracking-wider text-white/60">
          {t.contactTitle}
        </p>

        <div class="mt-4 grid gap-5 md:grid-cols-2">

          <!-- Hamilton -->
          <div class="contact-card rounded-3xl border border-white/10 bg-white/5 p-6">
            <p class="text-lg font-extrabold">{t.hamiltonTitle}</p>
            <p class="mt-2 text-white/70 leading-7">
              135 Bendamere Ave<br />
              Hamilton, ON L9C 1N4
            </p>
            <p class="mt-3 text-white/80 font-semibold">
              {t.phoneLabel} <a class="hover:text-white underline underline-offset-4" href="tel:+19053838371">905-383-8371</a>
            </p>
            <p class="mt-1 text-white/80 font-semibold">
              {t.emailLabel}
              <a class="hover:text-white underline underline-offset-4" href="mailto:leballonrouge@cscmonavenir.ca">
                leballonrouge@cscmonavenir.ca
              </a>
            </p>
            <p class="mt-3 text-white/70">{t.hoursHamilton}</p>
            <a href={`${base}/centres/#hamilton`} class="mt-4 inline-flex rounded-full bg-red-700 px-4 py-2 text-sm font-extrabold hover:bg-red-800">
              {t.seeOnMap}
            </a>
          </div>

          <!-- Brantford -->
          <div class="contact-card rounded-3xl border border-white/10 bg-white/5 p-6">
            <p class="text-lg font-extrabold">{t.brantfordTitle}</p>
            <p class="mt-2 text-white/70 leading-7">
              60 Clench Ave<br />
              Brantford, ON N3T 1B8
            </p>
            <p class="mt-3 text-white/80 font-semibold">
              {t.phoneLabel} <a class="hover:text-white underline underline-offset-4" href="tel:+15197536541">519-753-6541</a>
            </p>
            <p class="mt-1 text-white/80 font-semibold">
              {t.emailLabel}
              <a class="hover:text-white underline underline-offset-4" href="mailto:leballonrougebrantford@cscmonavenir.ca">
                leballonrougebrantford@cscmonavenir.ca
              </a>
            </p>
            <p class="mt-3 text-white/70">{t.hoursBrantford}</p>
            <a href={`${base}/centres/#brantford`} class="mt-4 inline-flex rounded-full bg-red-700 px-4 py-2 text-sm font-extrabold hover:bg-red-800">
              {t.seeOnMap}
            </a>
          </div>

        </div>

        <!-- Newsletter -->
        <div class="mt-6 rounded-3xl border border-white/10 bg-white/5 p-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-lg font-extrabold">{t.newsletterTitle}</p>
              <p class="mt-1 text-white/70">
                {t.newsletterDesc}
              </p>
            </div>

            <form class="flex w-full max-w-md gap-2" onsubmit="event.preventDefault(); alert('Merci! (Demo)');">
              <label class="sr-only" for="newsletterEmail">{t.newsletterEmailLabel}</label>
              <input
                id="newsletterEmail"
                type="email"
                required
                class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-red-500"
                placeholder={t.newsletterEmailPlaceholder}
              />
              <button class="rounded-2xl bg-red-700 px-5 py-3 font-extrabold hover:bg-red-800">
                {t.newsletterSubmit}
              </button>
            </form>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom row -->
    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-8 md:flex-row md:items-center md:justify-between">
      <p class="text-sm text-white/60">
        © <span id="year"></span> {t.brandName}. {t.bottomRights}.
      </p>

      <div class="flex flex-wrap gap-4 text-sm font-semibold text-white/70">
        <a href="#" class="hover:text-white">{t.privacy}</a>
        <a href="#" class="hover:text-white">{t.terms}</a>
        <a href={`${base}/inscription/`} class="hover:text-white">
          {t.requestSpot}
        </a>
      </div>
    </div>

  </div>

  <script is:inline>
    const yearEl = document.getElementById('year');
    if (yearEl) yearEl.textContent = String(new Date().getFullYear());
  </script>
</footer>