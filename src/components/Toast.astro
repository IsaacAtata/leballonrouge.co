<!--
  Branded success toast — shown after any form submission.
  JS in each page calls: window.showToast('Your message here')
  Auto-dismisses after 5 seconds.
-->

<div
  id="toast"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  class="fixed bottom-6 left-1/2 z-[9999] flex items-center gap-3 rounded-2xl border border-green-100 bg-white px-5 py-4 shadow-2xl shadow-black/10 transition-all duration-300"
>
  <!-- Icon -->
  <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-green-50">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
  </div>

  <!-- Text -->
  <div>
    <p id="toast-title" class="text-sm font-black text-slate-900">Merci!</p>
    <p id="toast-body" class="text-xs font-semibold text-slate-500">Votre demande a bien été envoyée.</p>
  </div>

  <!-- Close button -->
  <button
    id="toast-close"
    aria-label="Fermer"
    class="ml-2 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full text-slate-400 transition hover:bg-slate-100 hover:text-slate-600"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<style>
  #toast {
    /* Single source of truth for positioning — no Tailwind transform conflicts */
    transform: translateX(-50%) translateY(calc(100% + 1.5rem));
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  #toast.toast-visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script is:inline>
  (function () {
    var toast      = document.getElementById('toast');
    var toastTitle = document.getElementById('toast-title');
    var toastBody  = document.getElementById('toast-body');
    var closeBtn   = document.getElementById('toast-close');
    var hideTimer  = null;

    function hideToast() {
      clearTimeout(hideTimer);
      toast.classList.remove('toast-visible');
    }

    window.showToast = function (title, body) {
      toastTitle.textContent = title || 'Merci!';
      toastBody.textContent  = body  || 'Votre demande a bien été envoyée.';
      toast.classList.add('toast-visible');
      clearTimeout(hideTimer);
      hideTimer = setTimeout(hideToast, 5000);
    };

    window.handleFormSubmit = function (event, form, title, body) {
      event.preventDefault();

      var data = new FormData(form);

      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data).toString(),
      })
      .then(function () {
        window.showToast(title, body);
        form.reset();
      })
      .catch(function () {
        window.showToast(
          'Erreur réseau',
          'Veuillez réessayer ou nous contacter directement.'
        );
      });
    };

    closeBtn.addEventListener('click', hideToast);
  })();
</script>