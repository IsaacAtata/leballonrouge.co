---
import type { Lang } from "../i18n";
const { lang = "fr" } = Astro.props as { lang?: Lang };
const base = lang === "en" ? "/en" : "";
---

<section class="relative mx-auto max-w-7xl px-4 pb-12 pt-8 md:pt-16">

  <!-- Soft warm glow -->
  <div class="pointer-events-none absolute -left-20 -top-20 h-[400px] w-[400px] rounded-full bg-red-50 opacity-60 blur-3xl"></div>

  <div class="relative grid grid-cols-1 items-center gap-8 md:grid-cols-[1fr_1.8fr]">

    <!-- Left: text -->
    <div class="flex flex-col gap-4 md:gap-5">

      <!-- Location pills -->
      <div class="flex flex-wrap gap-2">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1.5 text-xs font-extrabold text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
          Hamilton
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1.5 text-xs font-extrabold text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
          Brantford
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-red-50 px-3 py-1.5 text-xs font-extrabold text-red-600">
          {lang === "en" ? "Ministry Licensed" : "Agréé Ministère"}
        </span>
      </div>

      <!-- Heading -->
      <h1 class="text-3xl font-black leading-[1.1] tracking-tight text-slate-900 sm:text-4xl md:text-4xl lg:text-5xl">
        {lang === "en" ? (
          <>Where French<br/>becomes an {" "}</>
        ) : (
          <>Là où le français<br/>devient une {" "}</>
        )}<span class="relative inline-block">
          <span class="relative z-10 text-red-700">
            {lang === "en" ? "adventure" : "aventure"}
          </span>
          <span class="absolute bottom-1 left-0 z-0 h-2.5 w-full rounded-full bg-red-100"></span>
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="text-sm font-medium leading-relaxed text-slate-500 sm:text-base">
        {lang === "en"
          ? "French-language daycare in Hamilton and Brantford — play-based learning, secure routines and daily French immersion."
          : "Service de garde francophone à Hamilton et Brantford — apprentissage par le jeu, routines sécurisantes et immersion française au quotidien."}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3">
        <a
          href={`${base}/inscription/`}
          class="group inline-flex items-center gap-2 rounded-full bg-red-700 px-6 py-3 text-sm font-extrabold text-white shadow-xl shadow-red-700/20 transition-all duration-150 hover:-translate-y-0.5 hover:bg-red-800 md:px-7 md:py-3.5"
        >
          {lang === "en" ? "Request a spot" : "Demander une place"}
          <!-- Arrow nudges right on hover via group-hover -->
          <span class="transition-transform duration-150 group-hover:translate-x-1">→</span>
        </a>
        <a
          href={`${base}/qui-sommes-nous/`}
          class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-6 py-3 text-sm font-extrabold text-slate-700 shadow-sm transition-all duration-150 hover:bg-slate-50 md:px-7 md:py-3.5"
        >
          {lang === "en" ? "About us!" : "À propos de nous!"}
        </a>
      </div>

      <!-- Trust line -->
      <p class="text-xs font-semibold text-slate-400 sm:text-sm">
        {lang === "en" ? "Serving since" : "En service depuis"} <strong class="text-slate-600">1986</strong> ·
        <strong class="text-slate-600">2</strong> {lang === "en" ? "centres" : "centres"} ·
        {lang === "en" ? "French" : "Français"} <strong class="text-slate-600">100%</strong> {lang === "en" ? "of the time" : "du temps"}
      </p>

    </div>

    <!-- Right: image -->
    <div class="flex flex-col gap-4">

      <!-- Skeleton placeholder with warm shimmer + floating balloon.
           When real photo is ready, remove this entire block and replace with:
           <img
             src="/assets/images/hero-children.jpg"
             alt="Enfants jouant au Ballon Rouge"
             class="w-full rounded-[28px] object-cover aspect-[16/9]"
             loading="eager"
             decoding="async"
             width="1280"
             height="720"
           /> -->
      <div class="relative">
        <!-- Ambient red glow behind the card -->
        <div class="pointer-events-none absolute -inset-4 rounded-[36px] bg-red-500/10 blur-2xl"></div>

        <!-- Skeleton card: shimmer sweep + floating balloon -->
        <div class="hero-img-skeleton">
          <div class="hero-img-skeleton-content">
            <!-- Balloon bobs up and down independently of shimmer -->
            <div class="hero-img-balloon">🎈</div>
            <p class="hero-img-label">
              {lang === "en" ? "Children's photo" : "Photo des enfants"}
            </p>
            <p class="hero-img-size">1280 × 720 px</p>
          </div>
        </div>
      </div>

      <!-- Stat chips — 2 cols on mobile, 4 on md+ -->
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        <div class="rounded-2xl border border-black/5 bg-white p-3 text-center shadow-sm">
          <p class="text-xl font-black text-red-700">40+</p>
          <p class="mt-0.5 text-[10px] font-semibold text-slate-500">
            {lang === "en" ? "years" : "ans"}
          </p>
        </div>
        <div class="rounded-2xl border border-black/5 bg-white p-3 text-center shadow-sm">
          <p class="text-xl font-black text-red-700">2</p>
          <p class="mt-0.5 text-[10px] font-semibold text-slate-500">
            {lang === "en" ? "centres" : "centres"}
          </p>
        </div>
        <div class="rounded-2xl border border-black/5 bg-white p-3 text-center shadow-sm">
          <p class="text-xl font-black text-red-700">100%</p>
          <p class="mt-0.5 text-[10px] font-semibold text-slate-500">
            {lang === "en" ? "French" : "Français"}
          </p>
        </div>
        <div class="rounded-2xl border border-black/5 bg-white p-3 text-center shadow-sm">
          <p class="text-xl font-black text-red-700">FR</p>
          <p class="mt-0.5 text-[10px] font-semibold text-slate-500">
            {lang === "en" ? "immersion" : "immersion"}
          </p>
        </div>
      </div>

    </div>

  </div>
</section>